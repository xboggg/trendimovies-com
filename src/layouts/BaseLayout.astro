---
import '../styles/global.css';
import Header from '../components/Header.svelte';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'video.movie' | 'video.tv_show';
  noIndex?: boolean;
}

const {
  title,
  description = 'Stream and download movies & TV series for free. High quality 720p and 1080p downloads available.',
  image = '/images/og-default.jpg',
  type = 'website',
  noIndex = false
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site || 'https://trendimovies.com');
// og:url should reflect query string so cache-bust params (?v=N) actually work as a cache bust
const ogUrl = new URL(Astro.url.pathname + Astro.url.search, Astro.site || 'https://trendimovies.com');
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <title>{title} | TrendiMovies</title>

  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />

  <meta name="theme-color" content="#e50914" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="TrendiMovies" />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image.startsWith("http") ? image : `https://trendimovies.com${image}`} />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:site_name" content="TrendiMovies" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image.startsWith("http") ? image : `https://trendimovies.com${image}`} />

  <!-- Preconnect to external resources -->
  <link rel="preconnect" href="https://image.tmdb.org" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Theme script (prevent flash) -->
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else if (theme === 'dark' || !theme) {
        document.documentElement.classList.add('dark');
      } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>

  <style is:inline>
    /* Background image with dark overlay */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url('/images/bg-cinema.webp');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      z-index: -2;
    }
    body::after {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.88) 50%, rgba(0,0,0,0.93) 100%);
      z-index: -1;
    }

    /* Compact, non-intrusive floating install card (bottom-right on desktop,
       a slim floating card with margins on mobile — never a full-width bar,
       so it doesn't cover the hero or the gold accent line). */
    #pwa-install-banner {
      position: fixed;
      bottom: 16px;
      right: 16px;
      left: auto;
      width: 320px;
      max-width: calc(100vw - 32px);
      background: rgba(20, 20, 22, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      padding: 12px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      z-index: 9999;
      box-shadow: 0 10px 40px rgba(0,0,0,0.5);
      gap: 10px;
      animation: pwa-slide-in 0.4s ease-out;
    }
    @keyframes pwa-slide-in {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    #pwa-install-banner .pwa-info {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
      min-width: 0;
    }
    #pwa-install-banner img {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      flex-shrink: 0;
    }
    #pwa-install-banner .pwa-text {
      min-width: 0;
    }
    #pwa-install-banner .pwa-title {
      font-weight: 700;
      color: white;
      font-size: 13px;
    }
    #pwa-install-banner .pwa-desc {
      font-size: 11px;
      color: rgba(255,255,255,0.65);
    }
    #pwa-install-banner .pwa-buttons {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }
    #pwa-install-banner .btn-install {
      padding: 7px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      border: none;
      background: linear-gradient(135deg, #fbbf24, #f59e0b);
      color: #000;
      font-weight: 700;
    }
    /* Dismiss is a small unobtrusive × */
    #pwa-install-banner .btn-later {
      width: 26px;
      height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      border-radius: 50%;
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
      background: rgba(255,255,255,0.08);
      border: none;
      color: rgba(255,255,255,0.7);
    }
    #pwa-install-banner .btn-later:hover {
      background: rgba(255,255,255,0.18);
      color: #fff;
    }
    @media (max-width: 480px) {
      #pwa-install-banner {
        left: 12px;
        right: 12px;
        width: auto;
        max-width: none;
        bottom: 12px;
      }
    }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <Header client:load pathname={Astro.url.pathname} />

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- Analytics Tracking -->
  <script is:inline>
    (function() {
      var sessionId = sessionStorage.getItem('tm_session_id');
      if (!sessionId) {
        sessionId = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
          var r = Math.random() * 16 | 0;
          return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
        });
        sessionStorage.setItem('tm_session_id', sessionId);
      }

      var path = window.location.pathname;
      if (path.startsWith('/admin') || path.startsWith('/api/')) {
        return;
      }

      fetch('/api/analytics/track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          page_path: path,
          referrer: document.referrer || '',
          session_id: sessionId
        })
      }).catch(function() {});
    })();
  </script>

  <!-- PWA Install Prompt & Service Worker -->
  <script is:inline>
    var deferredPrompt = null;

    window.addEventListener('beforeinstallprompt', function(e) {
      e.preventDefault();
      deferredPrompt = e;
      setTimeout(function() {
        if (deferredPrompt && !localStorage.getItem('pwa-dismissed')) {
          showInstallBanner();
        }
      }, 3000);
    });

    function showInstallBanner() {
      if (document.getElementById('pwa-install-banner')) return;
      var banner = document.createElement('div');
      banner.id = 'pwa-install-banner';
      banner.innerHTML = '<div class="pwa-info"><img src="/icons/icon-72x72.png" alt="TrendiMovies"><div class="pwa-text"><div class="pwa-title">Install TrendiMovies</div><div class="pwa-desc">Quick access from your home screen</div></div></div><div class="pwa-buttons"><button class="btn-install" onclick="installPWA()">Install</button><button class="btn-later" onclick="dismissInstall()" aria-label="Dismiss">&times;</button></div>';
      document.body.appendChild(banner);
    }

    window.installPWA = function() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function(result) {
          deferredPrompt = null;
          var el = document.getElementById('pwa-install-banner');
          if (el) el.remove();
        });
      }
    };

    window.dismissInstall = function() {
      localStorage.setItem('pwa-dismissed', 'true');
      var el = document.getElementById('pwa-install-banner');
      if (el) el.remove();
    };

    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('/sw.js').then(function(reg) {
          // Always check for an updated service worker on load.
          reg.update();
        }).catch(function() {});
      });
      // When a new service worker takes control, reload once so the fresh
      // CSS/JS is applied immediately (prevents stale styles sticking around).
      var swReloaded = false;
      navigator.serviceWorker.addEventListener('controllerchange', function() {
        if (swReloaded) return;
        swReloaded = true;
        window.location.reload();
      });
    }
  </script>

  <!-- "Jump Back In" is now recorded by the VideoPlayer component on mount
       (real intent to watch + captures episode), not on every detail-page visit. -->

</body>
</html>
