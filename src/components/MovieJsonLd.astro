---
interface Props {
  movie: {
    title: string;
    overview?: string;
    release_date?: string;
    runtime?: number;
    genres?: { name: string }[];
    vote_average?: number;
    vote_count?: number;
    poster_path?: string;
    cast_data?: { name: string }[];
    crew_data?: { name: string; job: string }[];
  };
  tmdbId: number;
}

const { movie, tmdbId } = Astro.props;

const directors = (movie.crew_data || []).filter((c) => c.job === 'Director');
const ogImage = movie.poster_path
  ? `https://image.tmdb.org/t/p/w780${movie.poster_path}`
  : 'https://trendimovies.com/images/og-default.jpg';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Movie",
  "name": movie.title,
  "description": movie.overview || "",
  "image": ogImage,
  "datePublished": movie.release_date || undefined,
  "duration": movie.runtime ? `PT${movie.runtime}M` : undefined,
  "genre": movie.genres?.map((g) => g.name) || [],
  "director": directors.map((d) => ({
    "@type": "Person",
    "name": d.name
  })),
  "actor": (movie.cast_data || []).slice(0, 10).map((a) => ({
    "@type": "Person",
    "name": a.name
  })),
  "aggregateRating": movie.vote_average ? {
    "@type": "AggregateRating",
    "ratingValue": movie.vote_average,
    "bestRating": 10,
    "ratingCount": movie.vote_count || 1
  } : undefined,
  "url": `https://trendimovies.com/movie/${tmdbId}`
};

// Remove undefined values
const cleanJsonLd = JSON.parse(JSON.stringify(jsonLd));
---

<script type="application/ld+json" set:html={JSON.stringify(cleanJsonLd)} />
