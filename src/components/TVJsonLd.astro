---
interface Episode {
  episode_number: number;
  season_number: number;
  name: string;
  air_date?: string;
  overview?: string;
}

interface Props {
  series: {
    title: string;
    overview?: string;
    first_air_date?: string;
    number_of_seasons?: number;
    number_of_episodes?: number;
    genres?: { name: string }[];
    vote_average?: number;
    vote_count?: number;
    poster_path?: string;
    cast_data?: { name: string }[];
  };
  tmdbId: number;
  episodes?: Episode[];
}

const { series, tmdbId, episodes = [] } = Astro.props;

const ogImage = series.poster_path
  ? `https://image.tmdb.org/t/p/w780${series.poster_path}`
  : 'https://trendimovies.com/images/og-default.jpg';

// Build episode list for schema
const episodeSchema = episodes.slice(0, 50).map((ep) => ({
  "@type": "TVEpisode",
  "episodeNumber": ep.episode_number,
  "seasonNumber": ep.season_number,
  "name": ep.name,
  "datePublished": ep.air_date || undefined,
  "description": ep.overview || undefined,
  "url": `https://trendimovies.com/tv/${tmdbId}?season=${ep.season_number}&episode=${ep.episode_number}`
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TVSeries",
  "name": series.title,
  "description": series.overview || "",
  "image": ogImage,
  "datePublished": series.first_air_date || undefined,
  "genre": series.genres?.map((g) => g.name) || [],
  "numberOfSeasons": series.number_of_seasons || undefined,
  "numberOfEpisodes": series.number_of_episodes || undefined,
  "actor": (series.cast_data || []).slice(0, 10).map((a) => ({
    "@type": "Person",
    "name": a.name
  })),
  "aggregateRating": series.vote_average ? {
    "@type": "AggregateRating",
    "ratingValue": series.vote_average,
    "bestRating": 10,
    "ratingCount": series.vote_count || 1
  } : undefined,
  "containsSeason": series.number_of_seasons ? Array.from({ length: series.number_of_seasons }, (_, i) => ({
    "@type": "TVSeason",
    "seasonNumber": i + 1,
    "url": `https://trendimovies.com/tv/${tmdbId}?season=${i + 1}`
  })) : undefined,
  "episode": episodeSchema.length > 0 ? episodeSchema : undefined,
  "url": `https://trendimovies.com/tv/${tmdbId}`
};

// Remove undefined values
const cleanJsonLd = JSON.parse(JSON.stringify(jsonLd));
---

<script type="application/ld+json" set:html={JSON.stringify(cleanJsonLd)} />
