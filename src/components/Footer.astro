---
// Footer component - Enhanced with decorative background elements
---

<footer class="footer-wrap relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="footer-bg-elements">
    <!-- Large circle outline -->
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>
    <!-- Film reel icons -->
    <div class="bg-icon icon-1">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <rect x="2" y="2" width="20" height="20" rx="2"/>
        <circle cx="8" cy="8" r="2"/>
        <circle cx="16" cy="8" r="2"/>
        <circle cx="8" cy="16" r="2"/>
        <circle cx="16" cy="16" r="2"/>
      </svg>
    </div>
    <div class="bg-icon icon-2">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="M2 8h20M2 16h20M8 4v16M16 4v16"/>
      </svg>
    </div>
    <div class="bg-icon icon-3">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <polygon points="5,3 19,12 5,21"/>
      </svg>
    </div>
  </div>

  <!-- Animated gradient border at top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-red-600/60 to-transparent animate-shimmer"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="footer-card rounded-2xl px-8 py-10 grid grid-cols-1 md:grid-cols-12 gap-10 items-start relative overflow-hidden">

      <!-- Left: Logo + Tagline + Newsletter -->
      <div class="col-span-1 md:col-span-5 relative z-10">
        <a href="/" class="inline-block mb-4" style="overflow:hidden;height:80px;">
          <img src="/images/logo.png" alt="TrendiMovies" style="display:block;height:90px;width:auto;margin-top:-4px;" />
        </a>

        <p class="text-gray-300 text-base leading-relaxed mb-6 max-w-sm">
          Stream and download the latest movies &amp; TV series in stunning quality — all in one place, completely free.
        </p>

        <!-- Newsletter - Compact -->
        <p class="text-white font-medium mb-3 text-sm">Subscribe to our newsletter</p>
        <form class="newsletter-form flex items-center" onsubmit="return false;">
          <input
            type="email"
            placeholder="Your email address"
            class="newsletter-input"
          />
          <button type="submit" class="newsletter-btn" aria-label="Subscribe">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Middle: Our Services -->
      <div class="col-span-1 md:col-span-3 relative z-10">
        <h3 class="footer-heading">Our Services</h3>
        <ul class="space-y-3">
          <li><a href="/" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">Home</span></a></li>
          <li><a href="/movies" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">Movies</span></a></li>
          <li><a href="/series" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">TV Shows</span></a></li>
          <li><a href="/trending" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">Trending</span></a></li>
          <li><a href="/request" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">Request Content</span></a></li>
        </ul>
      </div>

      <!-- Right: Resources -->
      <div class="col-span-1 md:col-span-2 relative z-10">
        <h3 class="footer-heading">Resources</h3>
        <ul class="space-y-3">
          <li><a href="/about" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">About</span></a></li>
          <li><a href="/contact" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">Contact</span></a></li>
          <li><a href="/dmca" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">DMCA</span></a></li>
          <li><a href="/terms" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">Terms</span></a></li>
          <li><a href="/privacy" class="footer-link"><span class="footer-arrow">&rarr;</span><span class="link-text">Privacy Policy</span></a></li>
        </ul>
      </div>

      <!-- Far Right: Social Icons (vertical) -->
      <div class="col-span-1 md:col-span-2 relative z-10 flex md:flex-col flex-row flex-wrap gap-3 justify-start md:items-end">
        <a href="https://t.me/+n6x4_P8DROA5ZDY0" target="_blank" rel="noopener noreferrer" class="social-circle telegram" aria-label="Telegram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
