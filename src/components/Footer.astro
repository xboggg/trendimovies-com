---
// Footer component - MovieEra inspired layout
---

<footer class="footer-wrap relative overflow-hidden">
  <!-- Animated gradient border at top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-red-600/60 to-transparent animate-shimmer"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="footer-card rounded-2xl px-8 py-10 grid grid-cols-1 md:grid-cols-12 gap-10 items-start relative overflow-hidden">

      <!-- Background movie-cinematic overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-gray-900/80 via-black/60 to-gray-900/80 rounded-2xl pointer-events-none"></div>

      <!-- Left: Logo + Tagline + Newsletter -->
      <div class="col-span-1 md:col-span-5 relative z-10">
        <a href="/" class="inline-block mb-4" style="overflow:hidden;height:80px;">
          <img src="/images/logo.png" alt="TrendiMovies" style="display:block;height:90px;width:auto;margin-top:-4px;" />
        </a>

        <p class="text-gray-300 text-base leading-relaxed mb-6 max-w-sm">
          Stream and download the latest movies &amp; TV series in stunning quality — all in one place, completely free.
        </p>

        <!-- Newsletter -->
        <p class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Subscribe to our newsletter</p>
        <form class="flex items-center gap-0" onsubmit="return false;">
          <input
            type="email"
            placeholder="Your email address"
            class="newsletter-input flex-1 rounded-l-full px-5 py-3 text-sm bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-red-500 transition-colors"
          />
          <button
            type="submit"
            class="newsletter-btn rounded-r-full px-5 py-3 flex items-center justify-center"
            aria-label="Subscribe"
          >
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Middle: Our Services -->
      <div class="col-span-1 md:col-span-3 relative z-10">
        <h3 class="footer-heading">Our Services</h3>
        <ul class="space-y-3">
          <li>
            <a href="/" class="footer-link">
              <span class="footer-arrow">&#8594;</span> Home
            </a>
          </li>
          <li>
            <a href="/movies" class="footer-link">
              <span class="footer-arrow">&#8594;</span> Movies
            </a>
          </li>
          <li>
            <a href="/series" class="footer-link">
              <span class="footer-arrow">&#8594;</span> TV Shows
            </a>
          </li>
          <li>
            <a href="/trending" class="footer-link">
              <span class="footer-arrow">&#8594;</span> Trending
            </a>
          </li>
          <li>
            <a href="/request" class="footer-link">
              <span class="footer-arrow">&#8594;</span> Request Content
            </a>
          </li>
        </ul>
      </div>

      <!-- Right: Resources -->
      <div class="col-span-1 md:col-span-2 relative z-10">
        <h3 class="footer-heading">Resources</h3>
        <ul class="space-y-3">
          <li>
            <a href="/about" class="footer-link">
              <span class="footer-arrow">&#8594;</span> About
            </a>
          </li>
          <li>
            <a href="/contact" class="footer-link">
              <span class="footer-arrow">&#8594;</span> Contact
            </a>
          </li>
          <li>
            <a href="/dmca" class="footer-link">
              <span class="footer-arrow">&#8594;</span> DMCA
            </a>
          </li>
          <li>
            <a href="/terms" class="footer-link">
              <span class="footer-arrow">&#8594;</span> Terms
            </a>
          </li>
          <li>
            <a href="/privacy" class="footer-link">
              <span class="footer-arrow">&#8594;</span> Privacy Policy
            </a>
          </li>
        </ul>
      </div>

      <!-- Far Right: Social Icons (vertical) -->
      <div class="col-span-1 md:col-span-2 relative z-10 flex md:flex-col flex-row flex-wrap gap-3 justify-start md:items-end">
        <!-- Telegram -->
        <a href="https://t.me/+n6x4_P8DROA5ZDY0" target="_blank" rel="noopener noreferrer" class="social-circle telegram" aria-label="Telegram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </a>
        <!-- Facebook -->
        <a href="https://facebook.com/trendimovies" target="_blank" rel="noopener noreferrer" class="social-circle facebook" aria-label="Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <!-- Twitter/X -->
        <a href="https://twitter.com/trendimovies" target="_blank" rel="noopener noreferrer" class="social-circle twitter" aria-label="Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <!-- Instagram -->
        <a href="https://instagram.com/trendimovies" target="_blank" rel="noopener noreferrer" class="social-circle instagram" aria-label="Instagram">
