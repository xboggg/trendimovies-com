        </a>
        <a href="https://twitter.com/trendimovies" target="_blank" rel="noopener noreferrer" class="social-circle twitter" aria-label="Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://instagram.com/trendimovies" target="_blank" rel="noopener noreferrer" class="social-circle instagram" aria-label="Instagram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a href="https://youtube.com/@trendimovies" target="_blank" rel="noopener noreferrer" class="social-circle youtube" aria-label="YouTube">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-gray-500 text-sm">
        &copy; Copyright {new Date().getFullYear()} TrendiMovies. All rights reserved.
      </p>
      <p class="text-gray-500 text-sm">
        Designed by <span id="admin-trigger" class="novastream-link" style="cursor:pointer;-webkit-tap-highlight-color:transparent;user-select:none;">NovaStream</span>
      </p>
      <p class="text-gray-600 text-xs text-center max-w-md">
        TrendiMovies does not host any content. All media is embedded from third-party sources.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-wrap {
    background: linear-gradient(180deg, #0a0a0a 0%, #0d0d0d 100%);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  /* Decorative background elements */
  .footer-bg-elements {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .bg-circle {
    position: absolute;
    border: 2px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
  }

  .circle-1 {
    width: 500px;
    height: 500px;
    top: -150px;
    right: 10%;
    animation: pulse-circle 8s ease-in-out infinite;
  }

  .circle-2 {
    width: 300px;
    height: 300px;
    bottom: -80px;
    left: 5%;
    animation: pulse-circle 6s ease-in-out infinite reverse;
  }

  @keyframes pulse-circle {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.08); }
  }

  .bg-icon {
    position: absolute;
    color: rgba(255, 255, 255, 0.08);
  }

  .icon-1 {
    width: 100px;
    height: 100px;
    top: 25%;
    right: 12%;
    animation: float-icon 10s ease-in-out infinite;
  }

  .icon-2 {
    width: 80px;
    height: 80px;
    bottom: 15%;
    right: 25%;
    animation: float-icon 8s ease-in-out infinite reverse;
  }

  .icon-3 {
    width: 50px;
    height: 50px;
    top: 35%;
    left: 40%;
    animation: float-icon 12s ease-in-out infinite;
  }

  @keyframes float-icon {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.5; }
    50% { transform: translateY(-15px) rotate(8deg); opacity: 0.9; }
  }

  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  .animate-shimmer {
    background: linear-gradient(90deg, transparent 0%, transparent 35%, #ef4444 50%, transparent 65%, transparent 100%);
    background-size: 200% 100%;
    animation: shimmer 4s ease-in-out infinite;
  }

  .footer-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
  }

  .footer-heading {
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1.25rem;
    letter-spacing: 0.03em;
  }

  .footer-link {
    color: #9ca3af;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    padding: 4px 0;
  }

  .footer-link .link-text {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .footer-link .link-text::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: #d4af37;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .footer-link:hover {
    color: #ffffff;
    transform: translateX(8px);
  }

  .footer-link:hover .link-text {
    color: #d4af37;
  }

  .footer-link:hover .link-text::after {
    width: 100%;
    background: #d4af37;
  }

  .footer-arrow {
    color: #d4af37;
    font-size: 1rem;
    line-height: 1;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.7;
  }

  .footer-link:hover .footer-arrow {
    transform: translateX(6px) scale(1.2);
    opacity: 1;
  }

  /* Newsletter - Compact */
  .newsletter-form {
    max-width: 280px;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    padding: 10px 16px;
    border-radius: 25px 0 0 25px;
    font-size: 0.875rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-right: none;
    color: #fff;
    transition: all 0.3s ease;
  }

  .newsletter-input::placeholder {
    color: #6b7280;
  }

  .newsletter-input:focus {
    outline: none;
    border-color: #ef4444;
    background: rgba(255, 255, 255, 0.12);
  }

  .newsletter-btn {
    padding: 10px 16px;
    border-radius: 0 25px 25px 0;
    background: #ef4444;
    border: 1px solid #ef4444;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .newsletter-btn:hover {
    background: #dc2626;
    transform: scale(1.05);
  }

  /* Social circles */
  .social-circle {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #9ca3af;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .social-circle:hover {
    transform: scale(1.15) translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  .social-circle.telegram:hover {
    background: #0088cc;
    border-color: #0088cc;
    color: white;
  }
  .social-circle.facebook:hover {
    background: #1877f2;
    border-color: #1877f2;
    color: white;
  }
  .social-circle.twitter:hover {
    background: #000;
    border-color: #fff;
    color: white;
  }
  .social-circle.instagram:hover {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    border-color: #dc2743;
    color: white;
  }
  .social-circle.youtube:hover {
    background: #ff0000;
    border-color: #ff0000;
    color: white;
  }

  .novastream-link {
    color: #d4af37;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .novastream-link:hover {
    color: #f5d78e;
    text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
  }
</style>

<script>
  // Secret admin access - tap "NovaStream" 5 times
  let tapCount = 0;
  let tapTimer = null;
  
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('admin-trigger');
    if (trigger) {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        tapCount++;
        
        if (tapTimer) clearTimeout(tapTimer);
        
        if (tapCount >= 5) {
          tapCount = 0;
          window.location.href = '/admin';
        } else {
          tapTimer = setTimeout(() => {
            tapCount = 0;
          }, 2000);
        }
      });
    }
  });
</script>
