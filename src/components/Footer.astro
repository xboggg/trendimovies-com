            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <!-- TikTok -->
        <a href="https://tiktok.com/@trendimovies" target="_blank" rel="noopener noreferrer" class="social-circle tiktok" aria-label="TikTok">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-gray-500 text-sm">
        &copy; Copyright {new Date().getFullYear()} TrendiMovies. All rights reserved.
      </p>
      <p class="text-gray-600 text-xs text-center max-w-md">
        TrendiMovies does not host any content. All media is embedded from third-party sources.
      </p>
      <p class="text-gray-500 text-sm">
        Designed by <a href="https://novastreamdigital.com" target="_blank" rel="noopener noreferrer" class="novastream-link">NovaStream</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-wrap {
    background: linear-gradient(180deg, #0a0a0a 0%, #0d0d0d 100%);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  .animate-shimmer {
    background: linear-gradient(90deg, transparent 0%, transparent 35%, #ef4444 50%, transparent 65%, transparent 100%);
    background-size: 200% 100%;
    animation: shimmer 4s ease-in-out infinite;
  }

  .footer-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
  }

  .footer-heading {
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1.25rem;
    letter-spacing: 0.03em;
  }

  .footer-link {
    color: #9ca3af;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: #ffffff;
  }

  .footer-arrow {
    color: #ef4444;
    font-size: 1rem;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .footer-link:hover .footer-arrow {
    transform: translateX(3px);
  }

  /* Newsletter */
  .newsletter-input {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
  }
  .newsletter-input::placeholder {
    color: #6b7280;
  }
  .newsletter-input:focus {
    outline: none;
    border-color: #ef4444;
    background: rgba(255, 255, 255, 0.12);
  }
  .newsletter-btn {
    background: #ef4444;
    border: 1px solid #ef4444;
    transition: background 0.2s ease;
    cursor: pointer;
  }
  .newsletter-btn:hover {
    background: #dc2626;
  }

  /* Social circles */
  .social-circle {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #9ca3af;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }

  .social-circle:hover {
    transform: scale(1.1);
  }

  .social-circle.telegram:hover {
    background: #0088cc;
    border-color: #0088cc;
    color: white;
  }
  .social-circle.facebook:hover {
    background: #1877f2;
    border-color: #1877f2;
    color: white;
  }
  .social-circle.twitter:hover {
    background: #111;
    border-color: #fff;
    color: white;
  }
  .social-circle.instagram:hover {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    border-color: #dc2743;
    color: white;
  }
  .social-circle.tiktok:hover {
    background: #000;
    border-color: #fe2c55;
    color: white;
  }

  .novastream-link {
    color: #ef4444;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .novastream-link:hover {
    color: #fca5a5;
  }
</style>
