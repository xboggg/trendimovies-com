---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.svelte';
import ContentRow from '../components/ContentRow.svelte';
import FeaturedSection from '../components/FeaturedSection.svelte';
import Collections from '../components/Collections.svelte';
import PickYourMood from '../components/PickYourMood.svelte';
import ContinueWatching from '../components/ContinueWatching.svelte';
import { getTrendingMovies, getNowPlayingMovies, getPopularMovies, getTopRatedMovies, getTrendingTV, getPopularTV, getOnTheAirTV, discoverMovies, getMovieDetails, getMovieGenres, getTVDetails, searchMovies } from '../lib/tmdb';
import topMoviesData from '../data/top_movies_by_year.json';

const POSTGREST_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'http://localhost:3001';

// Fetch latest additions from our database (movies with downloads, sorted by created_at)
async function getLatestAdditions() {
  // "Latest Additions" = recently-acquired recent-release content.
  //   - year filter: only current year + previous year (rolls automatically)
  //   - sort: by movies.updated_at DESC, which a PG trigger bumps whenever a
  //     download_link is inserted/updated. So a movie that gets new files today
  //     surfaces today, even if the row itself was created months ago.
  const currentYear = new Date().getFullYear();
  const minYear = currentYear - 1;
  try {
    const res = await fetch(
      `${POSTGREST_URL}/movies?has_downloads=eq.true&year=gte.${minYear}&order=updated_at.desc&limit=30&select=tmdb_id,title,year,poster_path,backdrop_path,vote_average,vote_count,popularity,overview,updated_at`
    );
    if (!res.ok) return [];
    return await res.json();
  } catch (e) {
    console.error('Failed to fetch latest additions:', e);
    return [];
  }
}

// Calculate date range for upcoming movies (future releases only - start from tomorrow)
const today = new Date();
const tomorrow = new Date(today);
tomorrow.setDate(tomorrow.getDate() + 1);
const tomorrowStr = tomorrow.toISOString().split('T')[0];
const threeMonthsLater = new Date(today);
threeMonthsLater.setMonth(threeMonthsLater.getMonth() + 3);
const futureStr = threeMonthsLater.toISOString().split('T')[0];

// Fetch all data from TMDB and our database in parallel
// All TMDB calls wrapped with safe fallbacks so one bad upstream call doesn't 500 the homepage.
const ARR: any = [];
const OBJ: any = { results: [] };
const [trending, nowPlaying, popular, topRatedRecent, upcomingData, trendingTV, popularTV, onTheAirTV, actionMovies, comedyMovies, romanceMovies, thrillerMovies, animeMovies, kDramaMovies, movieGenres, latestAdditions] = await Promise.all([
  getTrendingMovies('week').catch(() => ARR),
  getNowPlayingMovies().catch(() => ARR),
  getPopularMovies().catch(() => ARR),
  discoverMovies({ sort_by: 'vote_average.desc', 'vote_count.gte': '1000', 'primary_release_date.gte': '2015-01-01' }).catch(() => OBJ),
  discoverMovies({
    'primary_release_date.gte': tomorrowStr,
    'primary_release_date.lte': futureStr,
    sort_by: 'popularity.desc'
  }).catch(() => OBJ),
  getTrendingTV('week').catch(() => ARR),
  getPopularTV().catch(() => ARR),
  getOnTheAirTV().catch(() => ARR),
  discoverMovies({ with_genres: '28', sort_by: 'popularity.desc' }).catch(() => OBJ),
  discoverMovies({ with_genres: '35', sort_by: 'popularity.desc' }).catch(() => OBJ),
  discoverMovies({ with_genres: '10749', sort_by: 'popularity.desc' }).catch(() => OBJ),
  discoverMovies({ with_genres: '53', sort_by: 'popularity.desc' }).catch(() => OBJ),
  discoverMovies({ with_genres: '16', with_original_language: 'ja', sort_by: 'vote_average.desc', 'vote_count.gte': '500' }).catch(() => OBJ),
  discoverMovies({ with_original_language: 'ko', sort_by: 'vote_average.desc', 'vote_count.gte': '200' }).catch(() => OBJ),
  getMovieGenres().catch(() => ARR),
  getLatestAdditions().catch(() => ARR)
]);

const upcoming = (upcomingData?.results || []).filter((m: any) => m.poster_path && m.release_date && new Date(m.release_date) > new Date());

// Create a genre map for quick lookup
const genreMap = new Map(movieGenres.map((g: any) => [g.id, g.name]));

// Fetch detailed info for hero carousel items (top 8 trending)
const heroMovieIds = (trending || []).slice(0, 8).map((m: any) => m.id);
const heroDetailsPromises = heroMovieIds.map((id: number) => getMovieDetails(id).catch(() => null));
const heroDetails = await Promise.all(heroDetailsPromises);

// Load custom poster/backdrop overrides — any movie whose poster_path or backdrop_path
// in our DB starts with /images/ overrides TMDB on every section of the homepage.
// (Detail page already does this; homepage sections pull from TMDB so we re-apply here.)
async function getCustomImageOverrides(): Promise<Map<number, { poster_path?: string; backdrop_path?: string }>> {
  const map = new Map<number, { poster_path?: string; backdrop_path?: string }>();
  try {
    const res = await fetch(`${POSTGREST_URL}/movies?or=(poster_path.like.%2Fimages%2F*,backdrop_path.like.%2Fimages%2F*)&select=tmdb_id,poster_path,backdrop_path`);
    if (res.ok) {
      const rows: any[] = await res.json();
      for (const r of rows) {
        if (!r.tmdb_id) continue;
        const entry: { poster_path?: string; backdrop_path?: string } = {};
        if (r.poster_path && r.poster_path.startsWith('/images/')) entry.poster_path = r.poster_path;
        if (r.backdrop_path && r.backdrop_path.startsWith('/images/')) entry.backdrop_path = r.backdrop_path;
        map.set(r.tmdb_id, entry);
      }
    }
  } catch (e) {
    console.error('Failed to load image overrides:', e);
  }
  return map;
}
const imageOverrides = await getCustomImageOverrides();
function applyOverride(tmdbId: number, posterPath: string | null, backdropPath: string | null) {
  const ov = imageOverrides.get(tmdbId);
  return {
    poster_path: ov?.poster_path ?? posterPath,
    backdrop_path: ov?.backdrop_path ?? backdropPath
  };
}

// Transform for components
function transformMovie(m: any) {
  const ov = applyOverride(m.id, m.poster_path, m.backdrop_path);
  return {
    id: m.id,
    tmdb_id: m.id,
    title: m.title,
    poster_path: ov.poster_path,
    backdrop_path: ov.backdrop_path,
    vote_average: m.vote_average,
    vote_count: m.vote_count,
    popularity: m.popularity,
    year: m.release_date ? new Date(m.release_date).getFullYear() : null,
    release_date: m.release_date || null,
    overview: m.overview,
    genre_ids: m.genre_ids,
    type: 'movie' as const
  };
}

function transformTV(t: any) {
  const ov = applyOverride(t.id, t.poster_path, t.backdrop_path);
  return {
    id: t.id,
    tmdb_id: t.id,
    title: t.name,
    poster_path: ov.poster_path,
    backdrop_path: ov.backdrop_path,
    vote_average: t.vote_average,
    vote_count: t.vote_count,
    popularity: t.popularity,
    year: t.first_air_date ? new Date(t.first_air_date).getFullYear() : null,
    overview: t.overview,
    type: 'series' as const
  };
}

// Transform database movies to component format
function transformDbMovie(m: any) {
  return {
    id: m.tmdb_id,
    tmdb_id: m.tmdb_id,
    title: m.title,
    poster_path: m.poster_path,
    backdrop_path: m.backdrop_path,
    vote_average: m.vote_average || 0,
    vote_count: m.vote_count || 0,
    popularity: m.popularity || 0,
    year: m.year,
    overview: m.overview,
    updated_at: m.updated_at,
    type: 'movie' as const,
    has_downloads: true
  };
}

// Transform hero items with full details (tagline, runtime, genres)
const heroItems = (trending || []).slice(0, 8).map((m: any, index: number) => {
  const details = heroDetails[index];
  const ov = applyOverride(m.id, m.poster_path, m.backdrop_path);
  return {
    id: m.id,
    tmdb_id: m.id,
    title: m.title,
    poster_path: ov.poster_path,
    backdrop_path: ov.backdrop_path,
    vote_average: m.vote_average,
    vote_count: m.vote_count,
    popularity: m.popularity,
    year: m.release_date ? new Date(m.release_date).getFullYear() : null,
    release_date: m.release_date || null,
    overview: m.overview,
    type: 'movie' as const,
    // Full details from API
    tagline: details?.tagline || null,
    runtime: details?.runtime || null,
    release_date: m.release_date || details?.release_date || null,
    genres: details?.genres || (m.genre_ids || []).map((id: number) => ({ id, name: genreMap.get(id) || '' }))
  };
});

const trendingItems = (trending || []).slice(0, 20).map(transformMovie);
const featured = heroItems[0] || null;
const nowPlayingItems = (nowPlaying || []).map(transformMovie);
const popularItems = (popular || []).map(transformMovie);
const topRatedItems = (topRatedRecent?.results || []).slice(0, 20).map(transformMovie);

// Transform latest additions from database
const latestAdditionItems = (latestAdditions || []).map(transformDbMovie);

// The "Just Dropped" reel inside FeaturedSection spotlights the first 8 items
// that have artwork. Build the IDs it will use so the "Latest Additions" row
// below can SKIP them — no movie appears in both sections.
const reelSpotlightIds = new Set(
  latestAdditionItems
    .filter((m: any) => m.poster_path || m.backdrop_path)
    .slice(0, 8)
    .map((m: any) => m.id)
);
const latestAdditionsRowItems = latestAdditionItems.filter((m: any) => !reelSpotlightIds.has(m.id));

// Transform upcoming movies with full release date
const upcomingItems = (upcoming || []).map((m: any) => {
  const ov = applyOverride(m.id, m.poster_path, null);
  return {
    id: m.id,
    tmdb_id: m.id,
    title: m.title,
    poster_path: ov.poster_path,
    vote_average: m.vote_average,
    year: m.release_date ? new Date(m.release_date).getFullYear() : null,
    release_date: m.release_date,
    type: 'movie' as const
  };
});

const tvItems = (trendingTV || []).map(transformTV);
const popularTVItems = (popularTV || []).map(transformTV);

// Fetch DB-assigned recent episodes (last 7 days) + TMDB on-the-air list
let dbRecentEpisodes: any[] = [];
try {
  const dbRes = await fetch(`${POSTGREST_URL}/recent_episode_series?order=latest_added.desc&limit=30`);
  if (dbRes.ok) dbRecentEpisodes = await dbRes.json();
} catch(e) {}

const dbOnAirItems = dbRecentEpisodes
  .filter((r: any) => r.poster_path)
  .map((r: any) => {
    const s = String(r.season_number).padStart(2, '0');
    const e = String(r.episode_number).padStart(2, '0');
    return {
      id: r.tmdb_id,
      tmdb_id: r.tmdb_id,
      title: r.title,
      poster_path: r.poster_path,
      vote_average: r.vote_average,
      year: r.year,
      type: 'series' as const,
      episode_info: `S${s}E${e}`,
    };
  });

// Fetch TV details for on-the-air shows to get last_episode_to_air data
const onTheAirFiltered = (onTheAirTV || []).filter((t: any) => t.poster_path);
const onTheAirDetails = await Promise.all(
  onTheAirFiltered.map((t: any) => getTVDetails(t.id).catch(() => null))
);
const tmdbOnAirItems = onTheAirFiltered.map((t: any, index: number) => {
  const base = transformTV(t);
  const details = onTheAirDetails[index];
  const lastEp = details?.last_episode_to_air;
  if (lastEp && lastEp.season_number != null && lastEp.episode_number != null) {
    const s = String(lastEp.season_number).padStart(2, '0');
    const e = String(lastEp.episode_number).padStart(2, '0');
    return { ...base, episode_info: `S${s}E${e}` };
  }
  return base;
});
// Merge: DB results first, then TMDB (deduplicate by tmdb_id)
const dbTmdbIds = new Set(dbOnAirItems.map((x: any) => x.tmdb_id));
const onTheAirItems = [
  ...dbOnAirItems,
  ...tmdbOnAirItems.filter((x: any) => !dbTmdbIds.has(x.tmdb_id)),
];
const actionItems = (actionMovies?.results || []).slice(0, 15).map(transformMovie);
const comedyItems = (comedyMovies?.results || []).slice(0, 15).map(transformMovie);
const romanceItems = (romanceMovies?.results || []).slice(0, 15).map(transformMovie);
const thrillerItems = (thrillerMovies?.results || []).slice(0, 15).map(transformMovie);
const animeItems = (animeMovies?.results || []).slice(0, 15).map(transformMovie);
const kDramaItems = (kDramaMovies?.results || []).slice(0, 15).map(transformMovie);

// Oscar 2026 nominees - search TMDB for each
const oscarTitles = [
  'Sinners', 'One Battle After Another', 'Bugonia', 'F1', 'Frankenstein',
  'Hamnet', 'Marty Supreme', 'The Secret Agent', 'Sentimental Value', 'Train Dreams'
];

async function searchOscarMovie(title: string) {
  try {
    const result = await searchMovies(title, 1);
    if (result.results && result.results.length > 0) {
      const movie = result.results.find((m: any) => {
        const year = m.release_date ? new Date(m.release_date).getFullYear() : 0;
        return year >= 2024 && year <= 2026;
      }) || result.results[0];
      return transformMovie(movie);
    }
  } catch (e) {
    console.error(`Failed to search Oscar movie ${title}:`, e);
  }
  return null;
}

const oscarResults = await Promise.all(oscarTitles.map(searchOscarMovie));
const oscarMovies = oscarResults.filter((m): m is NonNullable<typeof m> => m !== null);

// Top Movies (current year) - sourced from curated list shipped in JSON
const currentYear = new Date().getFullYear();
const _topMoviesYear = topMoviesData.by_year[String(currentYear)] || topMoviesData.by_year[String(topMoviesData.years[0])] || [];
// Build PostgREST overlay so the homepage hero links to /movie/{slug} when we own the file
const _topTmdbIds = _topMoviesYear.slice(0, 20).map((m: any) => m.tmdb_id).filter((x: any): x is number => typeof x === 'number');
const _topLiveMap = new Map<number, { id: number; slug: string | null }>();
if (_topTmdbIds.length > 0) {
  try {
    const _r = await fetch(POSTGREST_URL + "/movies?tmdb_id=in.(" + _topTmdbIds.join(",") + ")&has_downloads=eq.true&select=id,slug,tmdb_id");
    if (_r.ok) {
      const _rows: Array<{id: number; slug: string | null; tmdb_id: number}> = await _r.json();
      for (const row of _rows) _topLiveMap.set(row.tmdb_id, { id: row.id, slug: row.slug });
    }
  } catch (_) { /* ignore, fall back to JSON */ }
}
const topMovies = _topMoviesYear.slice(0, 20).map((m: any) => {
  const live = m.tmdb_id ? _topLiveMap.get(m.tmdb_id) : undefined;
  return {
    // FeaturedSection uses /movie/{id} where id is tmdb_id
    id: m.tmdb_id || 0,
    title: m.title,
    poster_path: m.poster_path,
    backdrop_path: m.backdrop_path,
    vote_average: m.imdb || m.vote_average || 0,
    year: parseInt(String(currentYear), 10),
    in_db: !!live || (m.in_db && m.db_id),
  };
});

// Fetch box office from database
async function getBoxOfficeData() {
  try {
    const res = await fetch(
      `${POSTGREST_URL}/box_office_weekly?order=week_start.desc,rank.asc&limit=15`
    );
    if (!res.ok) return [];
    const data = await res.json();
    if (data.length === 0) return [];
    const latestWeek = data[0].week_start;
    return data.filter(d => d.week_start === latestWeek).slice(0, 7).map(d => ({
      rank: d.rank,
      title: d.movie_title,
      weekend_gross: d.three_day_gross ? `$${(d.three_day_gross / 1000000).toFixed(1)}M` : "-",
      total_gross: d.total_gross > 100000 ? `$${(d.total_gross / 1000000).toFixed(1)}M` : (d.three_day_gross ? `$${(d.three_day_gross / 1000000).toFixed(1)}M` : "-"),
      tmdb_id: d.tmdb_id || 0,
      poster_path: d.poster_path || null
    }));
  } catch (e) {
    console.error("Failed to fetch box office:", e);
    return [];
  }
}

// Fetch mood-specific genres
const [familyMovies, horrorMovies, sciFiMovies, dramaMovies, hindiMovies, animationMovies, historyMovies] = await Promise.all([
  discoverMovies({ with_genres: "10751", sort_by: "vote_average.desc", "vote_count.gte": "200" }),
  discoverMovies({ with_genres: "27", sort_by: "popularity.desc" }),
  discoverMovies({ with_genres: "878", sort_by: "vote_average.desc", "vote_count.gte": "300" }),
  discoverMovies({ with_genres: "18", sort_by: "vote_average.desc", "vote_count.gte": "500" }),
  discoverMovies({ with_original_language: "hi", sort_by: "popularity.desc" }),
  discoverMovies({ with_genres: "16", sort_by: "popularity.desc" }),
  discoverMovies({ with_genres: "36", sort_by: "vote_average.desc", "vote_count.gte": "500" }),
]);

const familyItems = (familyMovies?.results || []).slice(0, 8).map(transformMovie);
const horrorItems = (horrorMovies?.results || []).slice(0, 8).map(transformMovie);
const sciFiItems = (sciFiMovies?.results || []).slice(0, 8).map(transformMovie);
const dramaItems = (dramaMovies?.results || []).slice(0, 8).map(transformMovie);
const hindiItems = (hindiMovies?.results || []).slice(0, 8).map(transformMovie);
const animationItems = (animationMovies?.results || []).slice(0, 8).map(transformMovie);
const historyItems = (historyMovies?.results || []).slice(0, 8).map(transformMovie);

const moodData = [
  { id: "chill", emoji: "😌", label: "Chill", gradient: "linear-gradient(135deg, #06b6d4, #0284c7)", items: familyItems.slice(0, 4) },
  { id: "thrilling", emoji: "😰", label: "Thrilling", gradient: "linear-gradient(135deg, #dc2626, #991b1b)", items: thrillerItems.slice(0, 4) },
  { id: "laugh", emoji: "😂", label: "Laugh", gradient: "linear-gradient(135deg, #f59e0b, #ea580c)", items: comedyItems.slice(0, 4) },
  { id: "cry", emoji: "😢", label: "Cry", gradient: "linear-gradient(135deg, #7c3aed, #4f46e5)", items: dramaItems.slice(0, 4) },
  { id: "mind-blown", emoji: "🤯", label: "Mind-Blown", gradient: "linear-gradient(135deg, #059669, #0d9488)", items: sciFiItems.slice(0, 4) },
  { id: "nostalgic", emoji: "🥹", label: "Nostalgic", gradient: "linear-gradient(135deg, #be185d, #e11d48)", items: romanceItems.slice(0, 4) },
];

const collectionsData = [
  { id: "true-story", title: "True Story", subtitle: "Because real life is stranger than fiction", link: "/genre/history", gradient: "linear-gradient(135deg, #78716c 0%, #44403c 100%)", posters: historyItems.slice(0, 4).map((i) => i.poster_path).filter(Boolean) },
  { id: "animation", title: "Animation World", subtitle: "Stunning animated films", link: "/genre/animation", gradient: "linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%)", posters: animationItems.slice(0, 4).map((i) => i.poster_path).filter(Boolean) },
  { id: "sci-fi", title: "Mind-Bending Sci-Fi", subtitle: "Beyond imagination", link: "/genre/sci-fi", gradient: "linear-gradient(135deg, #059669 0%, #0d9488 100%)", posters: sciFiItems.slice(0, 4).map((i) => i.poster_path).filter(Boolean) },
  { id: "horror", title: "Nightmare Fuel", subtitle: "Sleep with the lights on", link: "/genre/horror", gradient: "linear-gradient(135deg, #1e1e1e 0%, #7f1d1d 100%)", posters: horrorItems.slice(0, 4).map((i) => i.poster_path).filter(Boolean) },
  { id: "bollywood", title: "Bollywood Hits", subtitle: "Best of Hindi cinema", link: "/category/bollywood", gradient: "linear-gradient(135deg, #f59e0b 0%, #e11d48 100%)", posters: hindiItems.slice(0, 4).map((i) => i.poster_path).filter(Boolean) },
  { id: "top-rated", title: "Highest Rated of All Time", subtitle: "The all-time greatest", link: "/top-rated", gradient: "linear-gradient(135deg, #f59e0b 0%, #ef4444 100%)", posters: topRatedItems.slice(0, 4).map((i) => i.poster_path).filter(Boolean) },
];

const boxOfficeData = await getBoxOfficeData();

// Search TMDB for box office movies to get posters
const boxOfficeWithPosters = await Promise.all(boxOfficeData.map(async (entry) => {
  try {
    const result = await searchMovies(entry.title, 1);
    if (result.results && result.results.length > 0) {
      const movie = result.results[0];
      return { ...entry, tmdb_id: movie.id, poster_path: movie.poster_path };
    }
  } catch (e) {}
  return entry;
}));
---

<BaseLayout title="Watch Movies & TV Series Online Free">
  <!-- Hero Section -->
  <!-- SEO H1 -->
  <h1 class="sr-only">Watch Movies &amp; TV Series Online Free - TrendiMovies</h1>
  <HeroCarousel
    client:load
    featured={featured}
    trending={heroItems}
  />

  <!-- Trending Movies -->
  {trendingItems.length > 0 && (
    <ContentRow
      client:load
      title="Trending This Week"
      items={trendingItems}
      seeAllLink="/trending"
      autoScroll={true}
    />
  )}

  <!-- Featured Section + Latest Additions:
       Desktop (lg+) order: Featured then Latest Additions.
       Mobile + tablet order: Latest Additions FIRST (directly below Trending
       This Week), then Featured. Done via flex `order` so desktop is unchanged. -->
  <div class="flex flex-col">
    <!-- Featured Section: Oscar + Tabs -->
    <div class="order-2 xl:order-1">
      <FeaturedSection
        client:load
        oscarMovies={oscarMovies}
        topMovies={topMovies}
        boxOffice={boxOfficeWithPosters}
        comingSoon={upcoming.slice(0, 10).map(transformMovie)}
        latestAdditions={latestAdditionItems}
      />
    </div>

    <!-- Latest Additions (from our database - movies with downloads).
         Excludes the titles already spotlighted in the "Just Dropped" reel
         above so nothing appears twice. -->
    {latestAdditionsRowItems.length > 0 && (
      <div class="order-1 xl:order-2">
        <ContentRow
          client:load
          title="More Just Added"
          items={latestAdditionsRowItems}
          seeAllLink="/movies/latest"
          autoScroll={false}
        />
      </div>
    )}
  </div>

  <!-- Now Playing -->
  {nowPlayingItems.length > 0 && (
    <ContentRow
      client:load
      title="Now Playing in Theaters"
      items={nowPlayingItems}
      seeAllLink="/movies?filter=now_playing"
      autoScroll={true}
    />
  )}

  <!-- Upcoming Movies -->
  {upcomingItems.length > 0 && (
    <ContentRow
      client:visible
      title="Coming Soon"
      items={upcomingItems}
      seeAllLink="/movies/upcoming"
    />
  )}

  <!-- Popular Movies -->
  {popularItems.length > 0 && (
    <ContentRow
      client:visible
      title="Popular Movies"
      items={popularItems}
      seeAllLink="/movies"
    />
  )}

  <!-- Trending TV -->
  {tvItems.length > 0 && (
    <ContentRow
      client:visible
      title="Trending TV Series"
      items={tvItems}
      seeAllLink="/series"
    />
  )}

  <!-- Continue Watching (client-side, reads from localStorage) -->
  <ContinueWatching client:load />

  <!-- Collections -->
  <Collections client:visible collections={collectionsData} />

  <!-- Pick Your Mood -->
  <PickYourMood client:visible moods={moodData} />

  <!-- New Episodes This Week -->
  {onTheAirItems.length > 0 && (
    <ContentRow
      client:visible
      title="New Episodes This Week"
      items={onTheAirItems}
      seeAllLink="/series/new-episodes"
    />
  )}

  <!-- Action Movies -->
  {actionItems.length > 0 && (
    <ContentRow
      client:visible
