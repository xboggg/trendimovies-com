---
import BaseLayout from '../layouts/BaseLayout.astro';
const POSTGREST_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'http://localhost:3001';

let topics: any[] = [];
try {
  const r = await fetch(`${POSTGREST_URL}/movie_topics?is_published=eq.true&order=sort_order.asc&select=id,slug,title,emoji,color`);
  if (r.ok) {
    topics = await r.json();
    await Promise.all(topics.map(async (t: any) => {
      const ir = await fetch(`${POSTGREST_URL}/movie_topic_items?topic_id=eq.${t.id}&order=position.asc&limit=6&select=poster_path`);
      t.posters = (ir.ok ? await ir.json() : []).map((i: any) => i.poster_path).filter(Boolean);
    }));
  }
} catch (e) {}
const P = (p: string) => p ? (p.startsWith('/images/') ? p : `https://image.tmdb.org/t/p/w342${p}`) : '/images/no-poster.svg';
const six = topics.slice(0, 6);
const three = topics.slice(0, 3);
---
<BaseLayout title="Movie Guides — Design Previews">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-black mb-2" style="color:var(--text-primary)">Movie Guides — 10 Design Concepts</h1>
    <p class="mb-10 text-sm" style="color:var(--text-muted)">Each numbered block is a different look. Tell me the number(s) you like.</p>

    <!-- 1. MAGAZINE EDITORIAL -->
    <h2 class="dh">① Magazine Editorial</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {three.map((t,i)=>(
        <a href="#" class="ed-card">
          <div class="ed-num">{String(i+1).padStart(2,'0')}</div>
          <div class="ed-rule" style={`background:${t.color}`}></div>
          <h3 class="ed-title">{t.title}</h3>
          <p class="ed-meta">{t.posters.length} films · curated</p>
          <span class="ed-link" style={`color:${t.color}`}>Read the guide →</span>
        </a>
      ))}
    </div>

    <!-- 2. TICKET STUB -->
    <h2 class="dh">② Cinema Ticket Stub</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {six.map((t)=>(
        <a href="#" class="ticket" style={`--c:${t.color}`}>
          <div class="ticket-main">
            <div class="ticket-top"><span>ADMIT ONE</span><span>{t.emoji}</span></div>
            <h3 class="ticket-title">{t.title}</h3>
            <div class="ticket-bar"></div>
            <p class="ticket-sub">{t.posters.length} FILMS · TRENDIMOVIES</p>
          </div>
          <div class="ticket-stub"><span>VIEW</span></div>
        </a>
      ))}
    </div>

    <!-- 3. BRUTALIST -->
    <h2 class="dh">③ Brutalist / Mono</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-16">
      {six.map((t,i)=>(
        <a href="#" class="brut" style={`--c:${t.color}`}>
          <div class="brut-tag">[{String(i+1).padStart(2,'0')}]</div>
          <h3 class="brut-title">{t.title.toUpperCase()}</h3>
          <div class="brut-foot">{t.posters.length}.FILMS //  VIEW_LIST →</div>
        </a>
      ))}
    </div>

    <!-- 4. SPINE / SHELF -->
    <h2 class="dh">④ Book/DVD Spines on a Shelf</h2>
    <div class="shelf mb-16">
      {six.map((t)=>(
        <a href="#" class="spine" style={`--c:${t.color}; background-image:linear-gradient(180deg, ${t.color}, ${t.color}cc)`}>
          <span class="spine-emoji">{t.emoji}</span>
          <span class="spine-title">{t.title}</span>
        </a>
      ))}
    </div>

    <!-- 5. HOVER POSTER MOSAIC -->
    <h2 class="dh">⑤ Poster Mosaic Wall (hover a card)</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {six.map((t)=>(
        <a href="#" class="mosaic" style={`--c:${t.color}`}>
          <div class="mosaic-grid">
            {t.posters.slice(0,6).map((p:string)=>(<img src={P(p)} alt="" loading="lazy"/>))}
          </div>
          <div class="mosaic-cap"><span class="text-2xl">{t.emoji}</span><h3>{t.title}</h3></div>
        </a>
      ))}
    </div>

    <!-- 6. DIAGONAL / SKEWED -->
    <h2 class="dh">⑥ Diagonal Skewed Cards</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-20 pt-4">
      {six.map((t)=>(
        <a href="#" class="skew" style={`--c:${t.color}`}>
          <div class="skew-inner">
            <div class="skew-posters">{t.posters.slice(0,3).map((p:string,j:number)=>(<img src={P(p)} alt="" style={`--j:${j}`} loading="lazy"/>))}</div>
            <div class="skew-cap"><span>{t.emoji}</span><h3>{t.title}</h3></div>
          </div>
        </a>
      ))}
    </div>

    <!-- 7. NEON SYNTHWAVE -->
    <h2 class="dh">⑦ Neon / Synthwave</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {six.map((t)=>(
        <a href="#" class="neon" style={`--c:${t.color}`}>
          <div class="neon-grid-bg"></div>
          <span class="neon-emoji">{t.emoji}</span>
          <h3 class="neon-title">{t.title}</h3>
          <span class="neon-link">▸ ENTER</span>
        </a>
      ))}
    </div>

    <!-- 8. VINYL / REEL DISCS -->
    <h2 class="dh">⑧ Vinyl / Film-Reel Discs</h2>
    <div class="flex flex-wrap gap-8 justify-center mb-16">
      {six.map((t)=>(
        <a href="#" class="vinyl" style={`--c:${t.color}`}>
          <div class="vinyl-disc"><img src={P(t.posters[0])} alt="" loading="lazy"/><div class="vinyl-hole"></div></div>
          <p class="vinyl-title">{t.emoji} {t.title}</p>
        </a>
      ))}
    </div>

    <!-- 9. GLASS / FROSTED OVERLAP -->
    <h2 class="dh">⑨ Frosted Glass over Poster</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {six.map((t)=>(
        <a href="#" class="glass" style={`background-image:url(${P(t.posters[0])})`}>
          <div class="glass-panel" style={`--c:${t.color}`}>
            <span class="text-3xl">{t.emoji}</span>
            <h3>{t.title}</h3>
            <span class="glass-link">View list →</span>
          </div>
        </a>
      ))}
    </div>

    <!-- 10. NUMBERED LIST / RANKED -->
    <h2 class="dh">⑩ Big-Number Ranked List</h2>
    <div class="ranked mb-16">
      {six.map((t,i)=>(
        <a href="#" class="rank-row" style={`--c:${t.color}`}>
          <span class="rank-n">{i+1}</span>
          <div class="rank-posters">{t.posters.slice(0,4).map((p:string)=>(<img src={P(p)} alt="" loading="lazy"/>))}</div>
          <div class="rank-text"><span class="text-xl">{t.emoji}</span><h3>{t.title}</h3></div>
          <span class="rank-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .dh{font-size:1.1rem;font-weight:800;color:var(--text-primary);margin:0 0 1rem;padding-bottom:.4rem;border-bottom:1px solid var(--border)}
  a{text-decoration:none}

  /* 1 editorial */
  .ed-card{display:block;padding:8px 4px;transition:transform .3s}
  .ed-card:hover{transform:translateY(-3px)}
  .ed-num{font:800 56px/1 Georgia,serif;color:var(--text-muted);opacity:.4}
  .ed-rule{width:46px;height:3px;margin:10px 0 14px}
  .ed-title{font:700 26px/1.15 Georgia,serif;color:var(--text-primary)}
  .ed-meta{font-size:12px;color:var(--text-muted);margin:10px 0}
  .ed-link{font-size:13px;font-weight:700}

  /* 2 ticket */
  .ticket{display:flex;height:150px;border-radius:12px;overflow:hidden;background:#16161f;border:1px solid var(--border);transition:transform .3s}
  .ticket:hover{transform:translateY(-4px) rotate(-.5deg)}
  .ticket-main{flex:1;padding:16px 18px;position:relative}
  .ticket-top{display:flex;justify-content:space-between;font:700 10px/1 monospace;letter-spacing:2px;color:var(--c)}
  .ticket-title{font:800 17px/1.2 system-ui;color:#fff;margin:14px 0 0}
  .ticket-bar{height:18px;margin:12px 0 6px;background:repeating-linear-gradient(90deg,#fff 0 2px,transparent 2px 4px);opacity:.6}
  .ticket-sub{font:600 9px/1 monospace;letter-spacing:1px;color:var(--text-muted)}
  .ticket-stub{width:54px;border-left:2px dashed rgba(255,255,255,.25);display:flex;align-items:center;justify-content:center;background:var(--c)}
  .ticket-stub span{writing-mode:vertical-rl;transform:rotate(180deg);font:800 12px monospace;letter-spacing:3px;color:#fff}

  /* 3 brutalist */
  .brut{display:block;background:#0c0c0c;border:3px solid #fff;padding:18px;transition:all .15s;box-shadow:6px 6px 0 var(--c)}
  .brut:hover{transform:translate(-3px,-3px);box-shadow:10px 10px 0 var(--c)}
  .brut-tag{font:800 13px monospace;color:var(--c)}
  .brut-title{font:800 19px/1.1 monospace;color:#fff;margin:10px 0 16px}
  .brut-foot{font:700 11px monospace;color:#aaa;border-top:2px solid #333;padding-top:10px}

  /* 4 spines */
  .shelf{display:flex;gap:10px;align-items:flex-end;height:240px;padding:0 6px 14px;border-bottom:6px solid #2a2a2a;overflow-x:auto}
  .spine{position:relative;flex:0 0 56px;height:220px;border-radius:4px 4px 0 0;display:flex;flex-direction:column;align-items:center;padding:14px 0;box-shadow:2px 0 8px rgba(0,0,0,.5),inset -8px 0 12px rgba(0,0,0,.3);transition:all .3s;border:1px solid rgba(255,255,255,.1)}
  .spine:hover{transform:translateY(-22px);flex-basis:64px}
  .spine-emoji{font-size:20px}
  .spine-title{writing-mode:vertical-rl;margin-top:12px;font:800 13px system-ui;color:#fff;text-shadow:0 1px 2px rgba(0,0,0,.6);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-height:160px}

  /* 5 mosaic */
  .mosaic{position:relative;display:block;height:200px;border-radius:14px;overflow:hidden;border:1px solid var(--border)}
  .mosaic-grid{position:absolute;inset:0;display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(2,1fr)}
  .mosaic-grid img{width:100%;height:100%;object-fit:cover;filter:brightness(.5);transition:filter .4s,transform .4s}
  .mosaic:hover .mosaic-grid img{filter:brightness(.85)}
  .mosaic-cap{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:16px;background:linear-gradient(0deg,rgba(0,0,0,.85),transparent 60%);z-index:2}
  .mosaic-cap h3{font:800 18px system-ui;color:#fff}

  /* 6 skew */
  .skew{display:block;perspective:800px}
  .skew-inner{position:relative;height:200px;border-radius:14px;overflow:hidden;background:#14141c;border:1px solid var(--border);transform:rotateY(-8deg) rotateX(2deg);transition:transform .4s;box-shadow:-12px 12px 30px rgba(0,0,0,.4)}
  .skew:hover .skew-inner{transform:rotateY(0) rotateX(0)}
  .skew-posters{position:absolute;inset:0}
  .skew-posters img{position:absolute;top:-10%;height:140%;right:calc(6% + var(--j)*22%);border-radius:6px;transform:rotate(calc(-6deg + var(--j)*4deg));box-shadow:-4px 6px 16px rgba(0,0,0,.5);opacity:calc(1 - var(--j)*.18)}
  .skew-cap{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:16px;background:linear-gradient(90deg,rgba(10,10,15,.95),rgba(10,10,15,.4) 70%);z-index:2}
  .skew-cap h3{font:800 18px system-ui;color:#fff}
  .skew-cap span{font-size:24px}

  /* 7 neon */
  .neon{position:relative;display:flex;flex-direction:column;justify-content:flex-end;height:180px;border-radius:14px;overflow:hidden;background:#0a0014;border:2px solid var(--c);box-shadow:0 0 18px -4px var(--c),inset 0 0 30px -10px var(--c);padding:18px;transition:box-shadow .3s}
  .neon:hover{box-shadow:0 0 30px -2px var(--c),inset 0 0 40px -8px var(--c)}
  .neon-grid-bg{position:absolute;left:0;right:0;bottom:0;height:55%;background:repeating-linear-gradient(90deg,transparent 0 24px,var(--c) 24px 25px),repeating-linear-gradient(0deg,transparent 0 24px,var(--c) 24px 25px);opacity:.25;transform:perspective(160px) rotateX(55deg);transform-origin:bottom}
  .neon-emoji{position:relative;font-size:24px}
  .neon-title{position:relative;font:900 19px system-ui;color:#fff;text-shadow:0 0 10px var(--c);margin-top:6px}
  .neon-link{position:relative;font:700 11px monospace;letter-spacing:2px;color:var(--c);margin-top:8px}

  /* 8 vinyl */
  .vinyl{display:flex;flex-direction:column;align-items:center;width:150px}
  .vinyl-disc{position:relative;width:150px;height:150px;border-radius:50%;overflow:hidden;background:#000;box-shadow:0 10px 30px rgba(0,0,0,.6),inset 0 0 0 8px #111,inset 0 0 0 9px var(--c);transition:transform .6s}
  .vinyl:hover .vinyl-disc{transform:rotate(120deg)}
  .vinyl-disc img{width:62%;height:62%;object-fit:cover;border-radius:50%;position:absolute;top:19%;left:19%}
  .vinyl-hole{position:absolute;top:46%;left:46%;width:8%;height:8%;background:#000;border-radius:50%;box-shadow:0 0 0 2px #333;z-index:2}
  .vinyl-title{margin-top:12px;font:700 13px system-ui;color:#fff;text-align:center;max-width:150px}

  /* 9 glass */
  .glass{position:relative;display:block;height:200px;border-radius:16px;overflow:hidden;background-size:cover;background-position:center}
  .glass-panel{position:absolute;inset:auto 0 0 0;padding:16px;backdrop-filter:blur(12px) saturate(1.4);background:rgba(10,10,15,.45);border-top:2px solid var(--c)}
  .glass-panel h3{font:800 18px system-ui;color:#fff;margin-top:2px}
  .glass-link{font:700 12px system-ui;color:#fff;opacity:.8}

  /* 10 ranked */
  .ranked{display:flex;flex-direction:column;gap:12px}
  .rank-row{display:flex;align-items:center;gap:18px;padding:12px 18px;border-radius:14px;background:#14141c;border:1px solid var(--border);transition:all .25s;overflow:hidden}
  .rank-row:hover{border-color:var(--c);background:#1a1a24}
  .rank-n{font:900 52px/1 system-ui;color:transparent;-webkit-text-stroke:2px var(--c);flex:0 0 50px;text-align:center}
  .rank-posters{display:flex;flex:0 0 auto}
  .rank-posters img{width:42px;height:62px;object-fit:cover;border-radius:5px;margin-left:-14px;border:2px solid #14141c;box-shadow:0 4px 10px rgba(0,0,0,.4)}
  .rank-posters img:first-child{margin-left:0}
  .rank-text{flex:1;min-width:0}
  .rank-text h3{font:800 17px system-ui;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .rank-arrow{font:800 22px system-ui;color:var(--c)}
</style>
