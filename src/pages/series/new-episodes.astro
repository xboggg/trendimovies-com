---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MovieCard from '../../components/MovieCard.svelte';
import { getOnTheAirTVPaginated, getTVDetails } from '../../lib/tmdb';

const POSTGREST_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'http://localhost:3001';

// Get current page from query params
const page = parseInt(Astro.url.searchParams.get('page') || '1');

// On page 1: prepend DB-assigned recent episodes (last 7 days)
let dbItems: any[] = [];
if (page === 1) {
  try {
    const dbRes = await fetch(`${POSTGREST_URL}/recent_episode_series?order=latest_added.desc&limit=50`);
    if (dbRes.ok) {
      const dbData = await dbRes.json();
      dbItems = dbData
        .filter((r: any) => r.poster_path)
        .map((r: any) => {
          const s = String(r.season_number).padStart(2, '0');
          const e = String(r.episode_number).padStart(2, '0');
          return {
            id: r.tmdb_id,
            tmdb_id: r.tmdb_id,
            title: r.title,
            poster_path: r.poster_path,
            vote_average: r.vote_average,
            year: r.year,
            type: 'series' as const,
            episode_info: `S${s}E${e}`,
          };
        });
    }
  } catch(e) {}
}

// Fetch 2 TMDB pages per app page (to get ~40 results, display 30)
const tmdbPage1 = (page - 1) * 2 + 1;
const tmdbPage2 = tmdbPage1 + 1;

const [response1, response2] = await Promise.all([
  getOnTheAirTVPaginated(tmdbPage1),
  getOnTheAirTVPaginated(tmdbPage2)
]);

const allShows = [...(response1.results || []), ...(response2.results || [])];
const filtered = allShows.filter((t: any) => t.poster_path).slice(0, 30);
const totalPages = Math.min(Math.ceil((response1.total_pages || 1) / 2), 250);

// Fetch details for each show in parallel to get last_episode_to_air
const details = await Promise.all(
  filtered.map((t: any) => getTVDetails(t.id).catch(() => null))
);

// Transform with episode info
const tmdbShows = filtered.map((t: any, index: number) => {
  const detail = details[index];
  const lastEp = detail?.last_episode_to_air;
  let episode_info: string | undefined;
  if (lastEp && lastEp.season_number != null && lastEp.episode_number != null) {
    const s = String(lastEp.season_number).padStart(2, '0');
    const e = String(lastEp.episode_number).padStart(2, '0');
    episode_info = `S${s}E${e}`;
  }
  return {
    id: t.id,
    tmdb_id: t.id,
    title: t.name,
    poster_path: t.poster_path,
    vote_average: t.vote_average,
    year: t.first_air_date ? new Date(t.first_air_date).getFullYear() : null,
    type: 'series' as const,
    episode_info,
  };
});

// Merge: DB results first (page 1 only), deduplicate by tmdb_id
const dbTmdbIds = new Set(dbItems.map((x: any) => x.tmdb_id));
const merged = [
  ...dbItems,
  ...tmdbShows.filter((x: any) => !dbTmdbIds.has(x.tmdb_id)),
];
// Round down to multiple of 6 so grid rows are always complete
const cols = 6;
const shows = merged.length % cols === 0 ? merged : merged.slice(0, Math.floor(merged.length / cols) * cols);
---

<BaseLayout
  title="New Episodes This Week"
  description="TV series with new episodes airing this week"
  image={shows[0]?.poster_path ? `https://image.tmdb.org/t/p/w780${shows[0].poster_path}` : '/images/og-default.jpg'}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold mb-2" style="color: var(--text-primary);">New Episodes This Week</h1>
        <p class="text-sm" style="color: var(--text-secondary);">
          TV series currently airing new episodes
        </p>
      </div>
    </div>

    <!-- Series Grid -->
    {shows.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 lg:grid-cols-6 gap-4">
        {shows.map(show => (
          <MovieCard client:visible item={show} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p style="color: var(--text-secondary);">No new episodes airing this week</p>
      </div>
    )}

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="flex justify-center mt-8 gap-2">
        {page > 1 && (
          <a
            href={`/series/new-episodes?page=${page - 1}`}
            class="px-4 py-2 rounded-lg"
            style="background-color: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border);"
          >
            Previous
          </a>
        )}

        <span class="px-4 py-2" style="color: var(--text-secondary);">
          Page {page} of {totalPages}
        </span>

        {page < totalPages && (
          <a
            href={`/series/new-episodes?page=${page + 1}`}
            class="px-4 py-2 rounded-lg"
            style="background-color: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border);"
          >
            Next
          </a>
        )}
      </div>
    )}
  </div>
</BaseLayout>
