---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MovieCard from '../../components/MovieCard.svelte';
import { discoverTV } from '../../lib/tmdb';

// Get page number
const page = parseInt(Astro.url.searchParams.get('page') || '1');

// Fetch ongoing series (status: Returning Series, recently aired)
const tmdbPage = page;
const ongoingResponse = await discoverTV({
  sort_by: 'popularity.desc',
  'first_air_date.lte': new Date().toISOString().split('T')[0],
  'air_date.gte': new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString().split('T')[0], // Last 90 days
  with_status: '0', // Returning Series
  'vote_count.gte': '20',
  page: tmdbPage.toString()
});

const series = ongoingResponse.results || [];
const totalPages = Math.min(ongoingResponse.total_pages || 1, 50);

function transformToItem(show: any) {
  return {
    id: show.id,
    tmdb_id: show.id,
    title: show.name,
    poster_path: show.poster_path,
    vote_average: show.vote_average,
    year: show.first_air_date ? new Date(show.first_air_date).getFullYear() : null,
    type: 'series' as const
  };
}
---

<BaseLayout title="Ongoing Series" description="Browse all ongoing TV series currently airing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold" style="color: var(--text-primary);">Ongoing Series</h1>
      <a href="/series" class="text-sm hover:underline" style="color: var(--accent);">
        &larr; Back to All Series
      </a>
    </div>

    {series.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-6">
        {series.map((show: any) => (
          <MovieCard
            id={show.id}
            title={show.name}
            posterPath={show.poster_path}
            year={show.first_air_date ? new Date(show.first_air_date).getFullYear() : null}
            rating={show.vote_average}
            type="series"
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-12" style="color: var(--text-secondary);">
        <p>No ongoing series found.</p>
      </div>
    )}

    {/* Pagination */}
    {totalPages > 1 && (
      <div class="flex justify-center items-center gap-2 mt-8">
        {page > 1 && (
          <a
            href={`/series/ongoing?page=${page - 1}`}
            class="px-4 py-2 rounded-lg"
            style="background-color: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border);"
          >
            Previous
          </a>
        )}
        <span class="px-4 py-2" style="color: var(--text-secondary);">
          Page {page} of {totalPages}
        </span>
        {page < totalPages && (
          <a
            href={`/series/ongoing?page=${page + 1}`}
            class="px-4 py-2 rounded-lg"
            style="background-color: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border);"
          >
            Next
          </a>
        )}
      </div>
    )}
  </div>
</BaseLayout>
