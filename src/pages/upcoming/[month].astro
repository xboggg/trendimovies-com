---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { discoverMovies } from '../../lib/tmdb';

// Get the month-year from URL params
const { month } = Astro.params;

if (!month) {
  return Astro.redirect('/upcoming');
}

// Parse month-year (e.g., "march-2026")
const parts = month.split('-');
if (parts.length !== 2) {
  return Astro.redirect('/upcoming');
}

const monthName = parts[0].charAt(0).toUpperCase() + parts[0].slice(1);
const year = parseInt(parts[1]);

// Map month name to number
const monthMap: Record<string, number> = {
  'January': 0, 'February': 1, 'March': 2, 'April': 3,
  'May': 4, 'June': 5, 'July': 6, 'August': 7,
  'September': 8, 'October': 9, 'November': 10, 'December': 11
};

const monthNum = monthMap[monthName];
if (monthNum === undefined || isNaN(year)) {
  return Astro.redirect('/upcoming');
}

// Calculate date range for this month
const startDate = new Date(year, monthNum, 1);
const endDate = new Date(year, monthNum + 1, 0); // Last day of month

// If this month is current month, start from tomorrow
const today = new Date();
let startStr: string;
if (year === today.getFullYear() && monthNum === today.getMonth()) {
  const tomorrow = new Date(today);
  tomorrow.setDate(tomorrow.getDate() + 1);
  startStr = tomorrow.toISOString().split('T')[0];
} else {
  startStr = startDate.toISOString().split('T')[0];
}

const endStr = endDate.toISOString().split('T')[0];

// Fetch movies for this month (3 pages = 60 movies max)
const [page1, page2, page3] = await Promise.all([
  discoverMovies({
    'primary_release_date.gte': startStr,
    'primary_release_date.lte': endStr,
    sort_by: 'popularity.desc',
    page: 1
  }),
  discoverMovies({
    'primary_release_date.gte': startStr,
    'primary_release_date.lte': endStr,
    sort_by: 'popularity.desc',
    page: 2
  }),
  discoverMovies({
    'primary_release_date.gte': startStr,
    'primary_release_date.lte': endStr,
    sort_by: 'popularity.desc',
    page: 3
  })
]);

const movies = [
  ...(page1?.results || []),
  ...(page2?.results || []),
  ...(page3?.results || [])
].filter((m: any) => m.poster_path && m.release_date);

// Generate all month tabs (from current month to Dec 2026)
interface MonthTab {
  label: string;
  shortLabel: string;
  year: number;
  slug: string;
  isActive: boolean;
}

const allMonths: MonthTab[] = [];
const currentYear = today.getFullYear();
const currentMonth = today.getMonth();

for (let y = currentYear; y <= 2026; y++) {
  const startM = y === currentYear ? currentMonth : 0;
  const endM = y === 2026 ? 11 : 11;

  for (let m = startM; m <= endM; m++) {
    const d = new Date(y, m, 1);
    const label = d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    const shortLabel = d.toLocaleDateString('en-US', { month: 'short' });
    const slug = `${d.toLocaleDateString('en-US', { month: 'long' }).toLowerCase()}-${y}`;

    allMonths.push({
      label,
      shortLabel,
      year: y,
      slug,
      isActive: slug === month
    });
  }
}

const displayMonth = `${monthName} ${year}`;

function getPosterUrl(path: string | null): string {
  if (!path) return '/images/no-poster.svg';
  return `https://image.tmdb.org/t/p/w342${path}`;
}

function formatReleaseDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
}

function getCountdownData(dateStr: string): { days: number; hours: number; minutes: number; seconds: number } {
  const releaseDate = new Date(dateStr);
  releaseDate.setHours(0, 0, 0, 0);
  const now = new Date();
  const diff = releaseDate.getTime() - now.getTime();

  if (diff <= 0) {
    return { days: 0, hours: 0, minutes: 0, seconds: 0 };
  }

  return {
    days: Math.floor(diff / (1000 * 60 * 60 * 24)),
    hours: Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)),
    minutes: Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60)),
    seconds: Math.floor((diff % (1000 * 60)) / 1000)
  };
}
---

<BaseLayout
  title={`Upcoming Movies - ${displayMonth} | TrendiMovies`}
  description={`Discover movies releasing in ${displayMonth}. Get release dates, trailers, and details for upcoming films.`}
>
  <!-- Header -->
  <section class="relative py-8 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-900/30 via-transparent to-pink-900/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-3xl md:text-4xl font-black mb-2" style="color: var(--text-primary);">
          <span class="text-purple-500">Upcoming</span> Movies
        </h1>
        <p class="text-lg" style="color: var(--text-secondary);">
          {movies.length} movies in {displayMonth}
        </p>
      </div>
    </div>
  </section>

  <!-- Month Tabs -->
  <section class="sticky top-0 z-40 py-3" style="background-color: var(--bg-primary); border-bottom: 1px solid var(--border);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-1">
        {allMonths.map((m) => (
          <a
            href={`/upcoming/${m.slug}`}
            class:list={["month-tab flex-shrink-0 px-4 py-2 rounded-lg text-sm font-medium transition-all", { active: m.isActive }]}
            style={!m.isActive ? "background-color: var(--bg-card); border: 1px solid var(--border); color: var(--text-primary);" : ""}
          >
            <span class="block text-center">{m.shortLabel}</span>
            <span class="block text-center text-xs" style={!m.isActive ? "color: var(--text-muted);" : ""}>{m.year}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Movies Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {movies.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
        {movies.map((movie: any) => {
          const countdown = getCountdownData(movie.release_date);
          return (
            <a href={`/movie/${movie.id}`} class="group movie-card" data-release={movie.release_date}>
              <div class="relative aspect-[2/3] rounded-xl overflow-hidden mb-2">
                <img
                  src={getPosterUrl(movie.poster_path)}
                  alt={movie.title}
                  class="w-full h-full object-cover transition-transform group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>

                <!-- Countdown Timer -->
                <div class="absolute top-2 left-2 right-2">
                  <div class="countdown-timer flex items-center justify-center gap-1" data-release={movie.release_date}>
                    <div class="countdown-box bg-red-600">
                      <span class="countdown-num" data-days>{String(countdown.days).padStart(2, '0')}</span>
                      <span class="countdown-label">D</span>
                    </div>
                    <div class="countdown-box bg-gray-800/90">
                      <span class="countdown-num" data-hours>{String(countdown.hours).padStart(2, '0')}</span>
                      <span class="countdown-label">H</span>
                    </div>
                    <div class="countdown-box bg-gray-800/90">
                      <span class="countdown-num" data-minutes>{String(countdown.minutes).padStart(2, '0')}</span>
                      <span class="countdown-label">M</span>
                    </div>
                    <div class="countdown-box bg-gray-800/90">
                      <span class="countdown-num" data-seconds>{String(countdown.seconds).padStart(2, '0')}</span>
                      <span class="countdown-label">S</span>
                    </div>
                  </div>
                </div>

                <!-- Rating if available -->
                {movie.vote_average > 0 && (
                  <div class="absolute bottom-2 left-2 px-2 py-1 rounded bg-black/70 text-amber-400 text-xs font-bold flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    {movie.vote_average.toFixed(1)}
                  </div>
                )}
              </div>
              <h3 class="text-sm font-medium line-clamp-2 group-hover:text-purple-400 transition-colors" style="color: var(--text-primary);">
                {movie.title}
              </h3>
              <p class="text-xs mt-1" style="color: var(--text-muted);">
                {formatReleaseDate(movie.release_date)}
              </p>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-xl" style="color: var(--text-muted);">No movies scheduled for {displayMonth}</p>
      </div>
    )}
  </section>

  <style>
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .month-tab.active {
      background: linear-gradient(135deg, #a855f7, #ec4899) !important;
      border-color: transparent !important;
      color: white !important;
    }

    .month-tab.active span {
      color: white !important;
    }

    .countdown-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4px 6px;
      border-radius: 4px;
      min-width: 28px;
    }

    .countdown-num {
      font-size: 12px;
      font-weight: 700;
      color: white;
      line-height: 1;
    }

    .countdown-label {
      font-size: 8px;
      font-weight: 600;
      color: rgba(255,255,255,0.8);
      margin-top: 1px;
    }

    @media (min-width: 640px) {
      .countdown-box {
        padding: 5px 7px;
        min-width: 32px;
      }
      .countdown-num {
        font-size: 14px;
      }
      .countdown-label {
        font-size: 9px;
      }
    }
  </style>

  <script>
    // Live countdown timer
    function updateCountdowns() {
      const timers = document.querySelectorAll('.countdown-timer');
      const now = new Date();

      timers.forEach((timer) => {
        const releaseStr = timer.getAttribute('data-release');
        if (!releaseStr) return;

        const releaseDate = new Date(releaseStr);
        releaseDate.setHours(0, 0, 0, 0);
        const diff = releaseDate.getTime() - now.getTime();

        if (diff <= 0) {
          const daysEl = timer.querySelector('[data-days]');
          const hoursEl = timer.querySelector('[data-hours]');
          const minutesEl = timer.querySelector('[data-minutes]');
          const secondsEl = timer.querySelector('[data-seconds]');
          if (daysEl) daysEl.textContent = '00';
          if (hoursEl) hoursEl.textContent = '00';
          if (minutesEl) minutesEl.textContent = '00';
          if (secondsEl) secondsEl.textContent = '00';
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        const daysEl = timer.querySelector('[data-days]');
        const hoursEl = timer.querySelector('[data-hours]');
        const minutesEl = timer.querySelector('[data-minutes]');
        const secondsEl = timer.querySelector('[data-seconds]');

        if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      });
    }

    // Update every second
    updateCountdowns();
    setInterval(updateCountdowns, 1000);

    // Scroll active tab into view
    const activeTab = document.querySelector('.month-tab.active');
    if (activeTab) {
      activeTab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }
  </script>
</BaseLayout>
