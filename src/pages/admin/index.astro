---
import AdminLayout from '../../layouts/AdminLayout.astro';
import StatsCard from '../../components/admin/StatsCard.svelte';
import DataTable from '../../components/admin/DataTable.svelte';
import { getDashboardStats } from '../../lib/admin-queries';

const stats = await getDashboardStats();
const analytics = (stats as any).analytics || {};

const movieDDLPercent = stats.totals.movies > 0
  ? Math.round((stats.ddlCoverage.moviesWithDDL / stats.totals.movies) * 100)
  : 0;

const episodeDDLPercent = stats.totals.episodes > 0
  ? Math.round((stats.ddlCoverage.episodesWithDDL / stats.totals.episodes) * 100)
  : 0;
---

<AdminLayout title="Dashboard" activeTab="dashboard">
  <!-- Overview Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <StatsCard
      label="Total Movies"
      value={stats.totals.movies}
      icon="film"
      color="red"
      subtext={`${stats.ddlCoverage.moviesWithDDL.toLocaleString()} with DDL`}
    />
    <StatsCard
      label="Total Series"
      value={stats.totals.series}
      icon="tv"
      color="blue"
    />
    <StatsCard
      label="Total Episodes"
      value={stats.totals.episodes}
      icon="play"
      color="green"
      subtext={`${stats.ddlCoverage.episodesWithDDL.toLocaleString()} with DDL`}
    />
    <StatsCard
      label="Download Links"
      value={stats.totals.downloadLinks}
      icon="link"
      color="purple"
      subtext={`${stats.linkCounts.movieLinks.toLocaleString()} movies, ${stats.linkCounts.episodeLinks.toLocaleString()} episodes`}
    />
  </div>

  <!-- Traffic Overview -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-5">
      <p class="text-sm text-[#666] mb-1">Total Page Views</p>
      <p class="text-2xl font-bold text-white">{(analytics.totalViews || 0).toLocaleString()}</p>
    </div>
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-5">
      <p class="text-sm text-[#666] mb-1">Views Today</p>
      <p class="text-2xl font-bold text-green-400">{(analytics.todayViews || 0).toLocaleString()}</p>
    </div>
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-5">
      <p class="text-sm text-[#666] mb-1">Views This Week</p>
      <p class="text-2xl font-bold text-blue-400">{(analytics.weekViews || 0).toLocaleString()}</p>
    </div>
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-5">
      <p class="text-sm text-[#666] mb-1">Unique Visitors (7d)</p>
      <p class="text-2xl font-bold text-purple-400">{(analytics.uniqueVisitors || 0).toLocaleString()}</p>
    </div>
  </div>

  <!-- Daily Trend Chart -->
  {analytics.dailyTrend && analytics.dailyTrend.length > 0 && (
  <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6 mb-8">
    <h3 class="text-lg font-semibold mb-4">Daily Traffic (Last 14 Days)</h3>
    <div class="overflow-x-auto">
      <div class="flex items-end gap-1 h-40 min-w-[600px]">
        {analytics.dailyTrend.map((d: any) => {
          const maxViews = Math.max(...analytics.dailyTrend.map((x: any) => x.views));
          const height = maxViews > 0 ? Math.max((d.views / maxViews) * 100, 2) : 2;
          const dateStr = new Date(d.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          return (
            <div class="flex flex-col items-center flex-1 group relative">
              <div class="absolute -top-8 bg-[#333] text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-10">
                {d.views.toLocaleString()} views / {d.unique_sessions.toLocaleString()} sessions
              </div>
              <div
                class="w-full bg-gradient-to-t from-red-600 to-red-400 rounded-t transition-all hover:from-red-500 hover:to-red-300"
                style={`height: ${height}%`}
              ></div>
              <span class="text-[10px] text-[#666] mt-1 rotate-[-45deg] origin-top-left">{dateStr}</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>
  )}

  <!-- DDL Coverage -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <h3 class="text-lg font-semibold mb-4">Movie DDL Coverage</h3>
      <div class="mb-4">
        <div class="flex justify-between text-sm mb-2">
          <span class="text-[#a0a0a0]">With Downloads</span>
          <span class="font-medium">{movieDDLPercent}%</span>
        </div>
        <div class="progress-bar">
          <div class="progress-bar-fill" style={`width: ${movieDDLPercent}%`}></div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div class="bg-[#0a0a0a] rounded-lg p-3">
          <p class="text-[#666] mb-1">With DDL</p>
          <p class="text-xl font-bold text-green-500">{stats.ddlCoverage.moviesWithDDL.toLocaleString()}</p>
        </div>
        <div class="bg-[#0a0a0a] rounded-lg p-3">
          <p class="text-[#666] mb-1">Without DDL</p>
          <p class="text-xl font-bold text-red-500">{stats.ddlCoverage.moviesWithoutDDL.toLocaleString()}</p>
        </div>
      </div>
    </div>

    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <h3 class="text-lg font-semibold mb-4">Episode DDL Coverage</h3>
      <div class="mb-4">
        <div class="flex justify-between text-sm mb-2">
          <span class="text-[#a0a0a0]">With Downloads</span>
          <span class="font-medium">{episodeDDLPercent}%</span>
        </div>
        <div class="progress-bar">
          <div class="progress-bar-fill" style={`width: ${episodeDDLPercent}%`}></div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div class="bg-[#0a0a0a] rounded-lg p-3">
          <p class="text-[#666] mb-1">With DDL</p>
          <p class="text-xl font-bold text-green-500">{stats.ddlCoverage.episodesWithDDL.toLocaleString()}</p>
        </div>
        <div class="bg-[#0a0a0a] rounded-lg p-3">
          <p class="text-[#666] mb-1">Without DDL</p>
          <p class="text-xl font-bold text-red-500">{stats.ddlCoverage.episodesWithoutDDL.toLocaleString()}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Country & Device Breakdown -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <h3 class="text-lg font-semibold mb-4">Top Countries (30 Days)</h3>
      <div class="space-y-2">
        {(analytics.viewsByCountry || []).map((c: any, i: number) => {
          const maxViews = analytics.viewsByCountry?.[0]?.views || 1;
          const width = Math.max((c.views / maxViews) * 100, 3);
          return (
            <div class="flex items-center gap-3">
              <span class="text-sm text-[#666] w-5 text-right">{i + 1}</span>
              <span class="text-sm font-medium w-28 truncate">{c.country_name}</span>
              <div class="flex-1 h-5 bg-[#0a0a0a] rounded overflow-hidden">
                <div class="h-full bg-gradient-to-r from-blue-600 to-blue-400 rounded" style={`width: ${width}%`}></div>
              </div>
              <span class="text-sm text-[#a0a0a0] w-16 text-right">{c.views.toLocaleString()}</span>
            </div>
          );
        })}
        {(!analytics.viewsByCountry || analytics.viewsByCountry.length === 0) && (
          <p class="text-[#666] text-sm">No data yet</p>
        )}
      </div>
    </div>

    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <h3 class="text-lg font-semibold mb-4">Device Breakdown (30 Days)</h3>
      <div class="space-y-3">
        {(analytics.viewsByDevice || []).map((d: any) => {
          const totalDeviceViews = (analytics.viewsByDevice || []).reduce((s: number, x: any) => s + x.views, 0);
          const pct = totalDeviceViews > 0 ? Math.round((d.views / totalDeviceViews) * 100) : 0;
          const color = d.device_type === 'mobile' ? 'from-green-600 to-green-400' :
                       d.device_type === 'desktop' ? 'from-blue-600 to-blue-400' :
                       d.device_type === 'tablet' ? 'from-purple-600 to-purple-400' : 'from-gray-600 to-gray-400';
          return (
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="font-medium capitalize">{d.device_type || 'Unknown'}</span>
                <span class="text-[#a0a0a0]">{d.views.toLocaleString()} ({pct}%)</span>
              </div>
              <div class="h-3 bg-[#0a0a0a] rounded overflow-hidden">
                <div class={`h-full bg-gradient-to-r ${color} rounded`} style={`width: ${pct}%`}></div>
              </div>
            </div>
          );
        })}
        {(!analytics.viewsByDevice || analytics.viewsByDevice.length === 0) && (
          <p class="text-[#666] text-sm">No data yet</p>
        )}
      </div>

      <!-- Download Link Stats -->
      <h3 class="text-lg font-semibold mt-8 mb-4">Download Links by Quality</h3>
      <div class="space-y-2">
        {Object.entries(stats.downloads.byQuality).map(([quality, count]) => (
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class={`w-3 h-3 rounded-full ${
                quality === '720p' ? 'bg-green-500' :
                quality === '1080p' ? 'bg-blue-500' :
                quality === '2160p' ? 'bg-purple-500' : 'bg-gray-500'
              }`}></span>
              <span class="font-medium text-sm">{quality}</span>
            </div>
            <span class="text-[#a0a0a0] text-sm">{(count as number).toLocaleString()} links</span>
          </div>
        ))}
      </div>

      <h3 class="text-lg font-semibold mt-6 mb-4">Download Links by Source</h3>
      <div class="space-y-2">
        {Object.entries(stats.downloads.bySource).map(([source, count]) => (
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class={`w-3 h-3 rounded-full ${
                source === 'telegram' ? 'bg-blue-400' :
                source === 'cinematika' ? 'bg-yellow-500' : 'bg-orange-500'
              }`}></span>
              <span class="font-medium text-sm capitalize">{source}</span>
            </div>
            <span class="text-[#a0a0a0] text-sm">{(count as number).toLocaleString()} links</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Link Counts -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-[#666] mb-1">Movie Download Links</p>
          <p class="text-2xl font-bold">{stats.linkCounts.movieLinks.toLocaleString()}</p>
        </div>
        <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
        </div>
      </div>
    </div>
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-[#666] mb-1">Episode Download Links</p>
          <p class="text-2xl font-bold">{stats.linkCounts.episodeLinks.toLocaleString()}</p>
        </div>
        <div class="w-10 h-10 rounded-lg bg-green-500/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-500"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Top Viewed Content (paginated, 10 per page) -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <h3 class="text-lg font-semibold mb-4">Top Viewed Movies (30 Days)</h3>
      <DataTable
        client:load
        columns={['#', 'Title', 'Year', 'Views']}
        rows={stats.topViewed.movies.map((m: any, i: number) => [
          i + 1,
          m.title,
          m.year || '-',
          (m.view_count || 0).toLocaleString()
        ])}
        emptyMessage="No view data yet"
        pageSize={10}
      />
    </div>

    <div class="bg-[#141414] rounded-xl border border-[#2a2a2a] p-6">
      <h3 class="text-lg font-semibold mb-4">Top Viewed Series (30 Days)</h3>
      <DataTable
        client:load
        columns={['#', 'Title', 'Year', 'Views']}
        rows={stats.topViewed.series.map((s: any, i: number) => [
          i + 1,
          s.title,
          s.year || '-',
          (s.view_count || 0).toLocaleString()
        ])}
        emptyMessage="No view data yet"
        pageSize={10}
      />
    </div>
  </div>
</AdminLayout>
