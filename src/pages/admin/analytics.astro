---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Analytics Dashboard" activeTab="analytics">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div></div>
      <select id="periodSelect" class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 text-white">
        <option value="24h">Last 24 Hours</option>
        <option value="7d" selected>Last 7 Days</option>
        <option value="30d">Last 30 Days</option>
        <option value="90d">Last 90 Days</option>
      </select>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-zinc-400 text-sm font-medium mb-2">Page Views</h3>
        <p id="pageViews" class="text-3xl font-bold text-red-500">-</p>
      </div>
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-zinc-400 text-sm font-medium mb-2">Unique Visitors</h3>
        <p id="uniqueVisitors" class="text-3xl font-bold text-red-500">-</p>
      </div>
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-zinc-400 text-sm font-medium mb-2">Searches</h3>
        <p id="searches" class="text-3xl font-bold text-red-500">-</p>
      </div>
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-zinc-400 text-sm font-medium mb-2">Downloads</h3>
        <p id="downloads" class="text-3xl font-bold text-red-500">-</p>
      </div>
    </div>

    <!-- Location & Device Stats -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Top Countries -->
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-lg font-semibold text-white mb-4">Top Countries</h3>
        <div id="topCountries" class="space-y-2 max-h-[300px] overflow-y-auto pr-2">
          <p class="text-zinc-500">Loading...</p>
        </div>
      </div>

      <!-- Devices -->
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-lg font-semibold text-white mb-4">Devices</h3>
        <div id="deviceStats" class="space-y-3">
          <p class="text-zinc-500">Loading...</p>
        </div>
      </div>

      <!-- Browsers -->
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-lg font-semibold text-white mb-4">Browsers</h3>
        <div id="browserStats" class="space-y-2 max-h-[300px] overflow-y-auto pr-2">
          <p class="text-zinc-500">Loading...</p>
        </div>
      </div>
    </div>

    <!-- Top Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Top Pages -->
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-lg font-semibold text-white mb-4">Top Pages</h3>
        <div id="topPages" class="space-y-2 max-h-[400px] overflow-y-auto pr-2">
          <p class="text-zinc-500">Loading...</p>
        </div>
      </div>

      <!-- Top Searches -->
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-lg font-semibold text-white mb-4">Top Searches</h3>
        <div id="topSearches" class="space-y-2 max-h-[400px] overflow-y-auto pr-2">
          <p class="text-zinc-500">Loading...</p>
        </div>
      </div>

      <!-- Top Downloads -->
      <div class="bg-zinc-900 rounded-xl p-6 border border-zinc-800">
        <h3 class="text-lg font-semibold text-white mb-4">Top Downloads</h3>
        <div id="topDownloads" class="space-y-2 max-h-[400px] overflow-y-auto pr-2">
          <p class="text-zinc-500">Loading...</p>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const countryFlags: Record<string, string> = {
    'US': 'ЁЯЗ║ЁЯЗ╕', 'GB': 'ЁЯЗмЁЯЗз', 'CA': 'ЁЯЗиЁЯЗж', 'AU': 'ЁЯЗжЁЯЗ║', 'DE': 'ЁЯЗйЁЯЗк',
    'FR': 'ЁЯЗлЁЯЗ╖', 'IN': 'ЁЯЗоЁЯЗ│', 'NG': 'ЁЯЗ│ЁЯЗм', 'GH': 'ЁЯЗмЁЯЗн', 'ZA': 'ЁЯЗ┐ЁЯЗж',
    'KE': 'ЁЯЗ░ЁЯЗк', 'BR': 'ЁЯЗзЁЯЗ╖', 'MX': 'ЁЯЗ▓ЁЯЗ╜', 'ES': 'ЁЯЗкЁЯЗ╕', 'IT': 'ЁЯЗоЁЯЗ╣',
    'NL': 'ЁЯЗ│ЁЯЗ▒', 'PL': 'ЁЯЗ╡ЁЯЗ▒', 'RU': 'ЁЯЗ╖ЁЯЗ║', 'JP': 'ЁЯЗпЁЯЗ╡', 'KR': 'ЁЯЗ░ЁЯЗ╖',
    'CN': 'ЁЯЗиЁЯЗ│', 'SG': 'ЁЯЗ╕ЁЯЗм', 'PH': 'ЁЯЗ╡ЁЯЗн', 'ID': 'ЁЯЗоЁЯЗй', 'MY': 'ЁЯЗ▓ЁЯЗ╛',
    'TH': 'ЁЯЗ╣ЁЯЗн', 'VN': 'ЁЯЗ╗ЁЯЗ│', 'PK': 'ЁЯЗ╡ЁЯЗ░', 'BD': 'ЁЯЗзЁЯЗй', 'EG': 'ЁЯЗкЁЯЗм',
    'AE': 'ЁЯЗжЁЯЗк', 'SA': 'ЁЯЗ╕ЁЯЗж', 'TR': 'ЁЯЗ╣ЁЯЗ╖', 'SE': 'ЁЯЗ╕ЁЯЗк', 'NO': 'ЁЯЗ│ЁЯЗ┤',
    'DK': 'ЁЯЗйЁЯЗ░', 'FI': 'ЁЯЗлЁЯЗо', 'AT': 'ЁЯЗжЁЯЗ╣', 'CH': 'ЁЯЗиЁЯЗн', 'BE': 'ЁЯЗзЁЯЗк',
    'PT': 'ЁЯЗ╡ЁЯЗ╣', 'GR': 'ЁЯЗмЁЯЗ╖', 'CZ': 'ЁЯЗиЁЯЗ┐', 'HU': 'ЁЯЗнЁЯЗ║', 'RO': 'ЁЯЗ╖ЁЯЗ┤',
    'UA': 'ЁЯЗ║ЁЯЗж', 'IL': 'ЁЯЗоЁЯЗ▒', 'AR': 'ЁЯЗжЁЯЗ╖', 'CL': 'ЁЯЗиЁЯЗ▒', 'CO': 'ЁЯЗиЁЯЗ┤',
    'PE': 'ЁЯЗ╡ЁЯЗк', 'VE': 'ЁЯЗ╗ЁЯЗк', 'NZ': 'ЁЯЗ│ЁЯЗ┐', 'IE': 'ЁЯЗоЁЯЗк', 'ZW': 'ЁЯЗ┐ЁЯЗ╝',
    'TZ': 'ЁЯЗ╣ЁЯЗ┐', 'UG': 'ЁЯЗ║ЁЯЗм', 'ET': 'ЁЯЗкЁЯЗ╣', 'CM': 'ЁЯЗиЁЯЗ▓', 'CI': 'ЁЯЗиЁЯЗо'
  };

  const deviceIcons: Record<string, string> = {
    'desktop': 'ЁЯЦея╕П',
    'mobile': 'ЁЯУ▒',
    'tablet': 'ЁЯУ▓'
  };

  const browserIcons: Record<string, string> = {
    'Chrome': 'ЁЯМР',
    'Firefox': 'ЁЯжК',
    'Safari': 'ЁЯзн',
    'Edge': 'ЁЯМК',
    'Opera': 'ЁЯФ┤',
    'Unknown': 'тЭУ'
  };

  function escapeHtml(str: string): string {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  function formatPagePath(path: string): string {
    const movieMatch = path.match(/^\/movie\/(\d+)/);
    if (movieMatch) return `ЁЯОм Movie #${movieMatch[1]}`;
    const tvMatch = path.match(/^\/tv\/(\d+)/);
    if (tvMatch) return `ЁЯУ║ TV #${tvMatch[1]}`;
    if (path === "/") return "ЁЯПа Home";
    if (path === "/movies") return "ЁЯОм Movies";
    if (path === "/movies/latest") return "ЁЯОм Latest Movies";
    if (path === "/tv") return "ЁЯУ║ TV Shows";
    if (path === "/search") return "ЁЯФН Search";
    if (path.startsWith("/genre/")) return `ЁЯП╖я╕П ${escapeHtml(path.replace("/genre/", "").replace(/-/g, " "))}`;
    return escapeHtml(path);
  }

  async function loadAnalytics() {
    const period = (document.getElementById("periodSelect") as HTMLSelectElement).value;
    try {
      const res = await fetch(`/api/analytics/stats?period=${period}`);
      const data = await res.json();

      if (data.success) {
        // Stats
        document.getElementById("pageViews")!.textContent = data.stats.pageViews.toLocaleString();
        document.getElementById("uniqueVisitors")!.textContent = data.stats.uniqueVisitors.toLocaleString();
        document.getElementById("searches")!.textContent = data.stats.searches.toLocaleString();
        document.getElementById("downloads")!.textContent = data.stats.downloads.toLocaleString();

        // Top Countries
        const countriesEl = document.getElementById("topCountries")!;
        if (data.countries && data.countries.length > 0) {
          countriesEl.innerHTML = data.countries.map((c: any) => {
            const flag = countryFlags[c.country_code] || 'ЁЯМН';
            return `<div class="flex justify-between items-center py-1.5 border-b border-gray-700/50">
              <span class="text-gray-300 text-sm">${flag} ${escapeHtml(c.country)}</span>
              <span class="text-red-400 font-semibold text-sm">${c.visitor_count.toLocaleString()}</span>
            </div>`;
          }).join("");
        } else {
          countriesEl.innerHTML = "<p class=\"text-gray-500\">No data yet</p>";
        }

        // Devices
        const devicesEl = document.getElementById("deviceStats")!;
        if (data.devices && data.devices.length > 0) {
          devicesEl.innerHTML = data.devices.map((d: any) => {
            const icon = deviceIcons[d.device_type] || 'тЭУ';
            const label = d.device_type.charAt(0).toUpperCase() + d.device_type.slice(1);
            return `<div class="mb-3">
              <div class="flex justify-between items-center mb-1">
                <span class="text-gray-300 text-sm">${icon} ${escapeHtml(label)}</span>
                <span class="text-gray-400 text-sm">${d.percentage}%</span>
              </div>
              <div class="w-full bg-gray-700 rounded-full h-2">
                <div class="bg-red-500 h-2 rounded-full" style="width: ${d.percentage}%"></div>
              </div>
            </div>`;
          }).join("");
        } else {
          devicesEl.innerHTML = "<p class=\"text-gray-500\">No data yet</p>";
        }

        // Browsers
        const browsersEl = document.getElementById("browserStats")!;
        if (data.browsers && data.browsers.length > 0) {
          browsersEl.innerHTML = data.browsers.map((b: any) => {
            const icon = browserIcons[b.browser] || 'ЁЯМР';
            return `<div class="flex justify-between items-center py-1.5 border-b border-gray-700/50">
              <span class="text-gray-300 text-sm">${icon} ${escapeHtml(b.browser)}</span>
              <span class="text-red-400 font-semibold text-sm">${b.percentage}%</span>
            </div>`;
          }).join("");
        } else {
          browsersEl.innerHTML = "<p class=\"text-gray-500\">No data yet</p>";
        }

        // Top Pages
        const topPagesEl = document.getElementById("topPages")!;
        if (data.topPages && data.topPages.length > 0) {
          topPagesEl.innerHTML = data.topPages.slice(0, 20).map((p: any) => {
            const displayName = formatPagePath(p.page_path);
            return `<div class="flex justify-between items-center py-1.5 border-b border-gray-700/50">
              <a href="${escapeHtml(p.page_path)}" target="_blank" class="text-gray-300 text-sm truncate mr-2 hover:text-red-400" title="${escapeHtml(p.page_path)}">${displayName}</a>
              <span class="text-red-400 font-semibold text-sm">${p.view_count}</span>
            </div>`;
          }).join("");
        } else {
          topPagesEl.innerHTML = "<p class=\"text-gray-500\">No data yet</p>";
        }

        // Top Searches
        const topSearchesEl = document.getElementById("topSearches")!;
        if (data.topSearches && data.topSearches.length > 0) {
          topSearchesEl.innerHTML = data.topSearches.slice(0, 20).map((s: any) => `
            <div class="flex justify-between items-center py-1.5 border-b border-gray-700/50">
              <span class="text-gray-300 text-sm truncate mr-2">${escapeHtml(s.query)}</span>
              <span class="text-red-400 font-semibold text-sm">${s.search_count}</span>
            </div>
          `).join("");
        } else {
          topSearchesEl.innerHTML = "<p class=\"text-gray-500\">No data yet</p>";
        }

        // Top Downloads
        const topDownloadsEl = document.getElementById("topDownloads")!;
        if (data.topDownloads && data.topDownloads.length > 0) {
          topDownloadsEl.innerHTML = data.topDownloads.slice(0, 20).map((d: any) => `
            <div class="flex justify-between items-center py-1.5 border-b border-gray-700/50">
              <span class="text-gray-300 text-sm truncate mr-2">${escapeHtml(d.title)}</span>
              <span class="text-red-400 font-semibold text-sm">${d.download_count}</span>
            </div>
          `).join("");
        } else {
          topDownloadsEl.innerHTML = "<p class=\"text-gray-500\">No data yet</p>";
        }
      }
    } catch (err) {
      console.error("Failed to load analytics:", err);
    }
  }

  document.getElementById("periodSelect")?.addEventListener("change", loadAnalytics);
  loadAnalytics();
</script>

<style>
  #topPages::-webkit-scrollbar, #topSearches::-webkit-scrollbar, #topDownloads::-webkit-scrollbar,
  #topCountries::-webkit-scrollbar, #browserStats::-webkit-scrollbar { width: 6px; }
  #topPages::-webkit-scrollbar-track, #topSearches::-webkit-scrollbar-track, #topDownloads::-webkit-scrollbar-track,
  #topCountries::-webkit-scrollbar-track, #browserStats::-webkit-scrollbar-track { background: transparent; }
  #topPages::-webkit-scrollbar-thumb, #topSearches::-webkit-scrollbar-thumb, #topDownloads::-webkit-scrollbar-thumb,
  #topCountries::-webkit-scrollbar-thumb, #browserStats::-webkit-scrollbar-thumb { background-color: #4B5563; border-radius: 3px; }
</style>
