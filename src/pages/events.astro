---
import BaseLayout from '../layouts/BaseLayout.astro';
import { filmEvents, getUpcomingEvents, getLiveEvents, getPastEvents, getDaysUntil } from '../lib/events';

const upcoming = getUpcomingEvents();
const live = getLiveEvents();
const past = getPastEvents();

// Format date range nicely
function formatDateRange(start: string, end: string): string {
  const s = new Date(start);
  const e = new Date(end);
  const opts: Intl.DateTimeFormatOptions = { month: 'short', day: 'numeric' };
  if (s.toDateString() === e.toDateString()) {
    return s.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  }
  if (s.getMonth() === e.getMonth()) {
    return `${s.toLocaleDateString('en-US', opts)} – ${e.getDate()}, ${s.getFullYear()}`;
  }
  return `${s.toLocaleDateString('en-US', opts)} – ${e.toLocaleDateString('en-US', opts)}, ${s.getFullYear()}`;
}

function formatShortDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Next upcoming event
const nextEvent = upcoming[0];
const daysToNext = nextEvent ? getDaysUntil(nextEvent.startDate) : 0;
---

<BaseLayout
  title="Film & Awards Events 2026 | TrendiMovies"
  description="Complete calendar of upcoming, live and past film festivals and award ceremonies — Cannes, Oscars, Venice, TIFF, Emmys and more."
>

  <!-- ── HERO ───────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden pt-8 pb-12 sm:pt-12 sm:pb-20" style="background: linear-gradient(135deg, #0a0a0a 0%, #0f0a1a 50%, #0a0a0f 100%);">
    <!-- Decorative blobs -->
    <div class="absolute top-0 left-0 w-96 h-96 rounded-full opacity-10 pointer-events-none" style="background: radial-gradient(circle, #B50C1B, transparent 70%); transform: translate(-30%, -30%);"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full opacity-10 pointer-events-none" style="background: radial-gradient(circle, #F7D000, transparent 70%); transform: translate(30%, 30%);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium mb-6" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); color: var(--text-secondary);">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        {upcoming.length} upcoming events in 2026–2027
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-white mb-4 leading-tight">
        Film &amp; Awards<br>
        <span style="background: linear-gradient(135deg, #F7D000, #B50C1B); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Events Calendar</span>
      </h1>
      <p class="text-gray-400 text-base sm:text-lg max-w-xl mx-auto mb-8">
        Track every major film festival and awards ceremony — from Cannes to the Oscars.
      </p>

      <!-- Stats row -->
      <div class="flex flex-wrap justify-center gap-4 sm:gap-8">
        {[
          { value: upcoming.length, label: 'Upcoming', color: '#22c55e' },
          { value: live.length, label: 'Live Now', color: '#F7D000' },
          { value: past.length, label: 'Past Events', color: '#6b7280' },
        ].map(({ value, label, color }) => (
          <div class="text-center">
            <div class="text-3xl font-black" style={`color: ${color};`}>{value}</div>
            <div class="text-xs uppercase tracking-widest text-gray-500 mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── NEXT EVENT SPOTLIGHT ───────────────────────────────────────────────── -->
  {nextEvent && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 sm:-mt-10 mb-16 relative z-10">
      <a href={nextEvent.pageUrl} class="block group">
        <div class="rounded-2xl overflow-hidden relative" style={`border: 1px solid ${nextEvent.color}40;`}>
          <!-- Background gradient -->
          <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${nextEvent.color}22 0%, ${nextEvent.accentColor}10 100%);`}></div>
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style={`background: linear-gradient(135deg, ${nextEvent.color}35 0%, ${nextEvent.accentColor}18 100%);`}></div>

          <div class="relative p-6 sm:p-8 lg:p-10">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
              <!-- Left info -->
              <div class="flex items-start gap-5">
                <div class="text-5xl sm:text-6xl leading-none flex-shrink-0">{nextEvent.emoji}</div>
                <div>
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider" style={`background: ${nextEvent.color}30; color: ${nextEvent.color === '#B50C1B' ? '#ff6b7a' : nextEvent.accentColor}; border: 1px solid ${nextEvent.color}40;`}>
                      Next Event
                    </span>
                    {nextEvent.edition && (
                      <span class="px-3 py-1 rounded-full text-xs font-medium" style="background: rgba(255,255,255,0.06); color: var(--text-secondary); border: 1px solid rgba(255,255,255,0.1);">
                        {nextEvent.edition} Edition
                      </span>
                    )}
                  </div>
                  <h2 class="text-2xl sm:text-3xl font-black text-white group-hover:text-yellow-300 transition-colors">{nextEvent.shortName}</h2>
                  <p class="text-gray-300 mt-1 flex items-center gap-2 flex-wrap text-sm sm:text-base">
                    <span>📅 {formatDateRange(nextEvent.startDate, nextEvent.endDate)}</span>
                    <span class="hidden sm:inline text-gray-600">·</span>
                    <span class="hidden sm:inline">📍 {nextEvent.location}</span>
                  </p>
                  <p class="text-gray-400 mt-2 text-sm max-w-lg hidden sm:block">{nextEvent.description}</p>
                </div>
              </div>

              <!-- Right countdown -->
              <div class="flex sm:flex-col items-center gap-3 sm:gap-1 sm:text-right">
                <div class="text-4xl sm:text-5xl font-black" style={`color: ${nextEvent.accentColor};`}>{daysToNext}</div>
                <div class="text-sm sm:text-base text-gray-400 font-medium">days to go</div>
                <div class="ml-auto sm:ml-0 mt-2 px-4 py-2 rounded-lg text-sm font-semibold text-white group-hover:scale-105 transition-transform" style={`background: ${nextEvent.color};`}>
                  View Event →
                </div>
              </div>
            </div>
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- ── LIVE NOW ───────────────────────────────────────────────────────────── -->
  {live.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
        <h2 class="text-2xl font-black text-white">Happening Now</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {live.map(event => (
          <a href={event.pageUrl} class="group block rounded-2xl overflow-hidden relative transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl" style={`background-color: var(--bg-card); border: 2px solid ${event.color};`}>
            <div class="absolute top-0 left-0 right-0 h-1" style={`background: linear-gradient(90deg, ${event.color}, ${event.accentColor});`}></div>
            <div class="p-5">
              <div class="flex items-start justify-between gap-3 mb-3">
                <span class="text-4xl">{event.emoji}</span>
                <span class="px-2 py-1 rounded-full text-xs font-bold animate-pulse" style="background: rgba(239,68,68,0.2); color: #f87171; border: 1px solid rgba(239,68,68,0.4);">● LIVE</span>
              </div>
              <h3 class="text-lg font-bold text-white group-hover:text-yellow-300 transition-colors">{event.shortName}</h3>
              <p class="text-sm text-gray-400 mt-1">{event.location}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── UPCOMING EVENTS ───────────────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-1 h-8 rounded-full" style="background: linear-gradient(180deg, #22c55e, #16a34a);"></div>
      <h2 class="text-2xl sm:text-3xl font-black" style="color: var(--text-primary);">Upcoming Events</h2>
    </div>

    <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-5">
      {upcoming.map((event, idx) => {
        const days = getDaysUntil(event.startDate);
        const isFirst = idx === 0;
        return (
          <a
            href={event.pageUrl}
            class="group relative block rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
            style={`background-color: var(--bg-card); border: 1px solid ${isFirst ? event.color + '60' : 'var(--border)'};`}
          >
            <!-- Top color bar -->
            <div class="h-1.5 w-full" style={`background: linear-gradient(90deg, ${event.color}, ${event.accentColor});`}></div>

            <!-- Subtle background glow on first -->
            {isFirst && (
              <div class="absolute inset-0 opacity-5 pointer-events-none" style={`background: radial-gradient(ellipse at top, ${event.color}, transparent 70%);`}></div>
            )}

            <div class="p-5 sm:p-6 relative">
              <!-- Header row -->
              <div class="flex items-start justify-between gap-3 mb-4">
                <div class="flex items-center gap-3">
                  <span class="text-3xl sm:text-4xl">{event.emoji}</span>
                  <div>
                    {event.edition && (
                      <p class="text-xs font-medium mb-0.5" style="color: var(--text-muted);">{event.edition} Edition</p>
                    )}
                    <h3 class="font-black text-base sm:text-lg text-white group-hover:text-yellow-300 transition-colors leading-tight">{event.shortName}</h3>
                  </div>
                </div>
                <!-- Days badge -->
                <div class="flex-shrink-0 text-center rounded-xl px-3 py-2" style={`background: ${event.color}20; border: 1px solid ${event.color}40;`}>
                  <div class="text-xl font-black" style={`color: ${event.accentColor === '#FFFFFF' ? event.color : event.accentColor};`}>{days}</div>
                  <div class="text-[10px] uppercase tracking-wider text-gray-500">days</div>
                </div>
              </div>

              <!-- Date & Location -->
              <div class="space-y-1.5 mb-4">
                <div class="flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
                  <span class="text-base">📅</span>
                  <span>{formatDateRange(event.startDate, event.endDate)}</span>
                </div>
                <div class="flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
                  <span class="text-base">📍</span>
                  <span>{event.location}</span>
                </div>
                {event.topAward && (
                  <div class="flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
                    <span class="text-base">🏆</span>
                    <span>Top prize: <strong style={`color: ${event.accentColor === '#FFFFFF' ? '#ddd' : event.accentColor};`}>{event.topAward}</strong></span>
                  </div>
                )}
              </div>

              <!-- Categories pills (max 4) -->
              <div class="flex flex-wrap gap-1.5 mb-4">
                {event.categories.slice(0, 4).map(cat => (
                  <span class="px-2 py-0.5 rounded text-[10px] font-medium" style={`background: ${event.color}18; color: var(--text-muted); border: 1px solid ${event.color}25;`}>
                    {cat}
                  </span>
                ))}
                {event.categories.length > 4 && (
                  <span class="px-2 py-0.5 rounded text-[10px] font-medium" style="background: var(--bg-hover); color: var(--text-muted);">
                    +{event.categories.length - 4} more
                  </span>
                )}
              </div>

              <!-- CTA -->
              <div class="flex items-center justify-between">
                <span class="text-xs" style="color: var(--text-muted);">{event.venue}</span>
                {event.pageUrl !== '/events' ? (
                  <span class="text-xs font-semibold flex items-center gap-1 group-hover:gap-2 transition-all" style={`color: ${event.accentColor === '#FFFFFF' ? '#ddd' : event.accentColor};`}>
                    View Page <span>→</span>
                  </span>
                ) : (
                  <span class="text-xs" style="color: var(--text-muted);">Coming soon</span>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- ── PAST EVENTS ───────────────────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-1 h-8 rounded-full" style="background: linear-gradient(180deg, #6b7280, #4b5563);"></div>
      <h2 class="text-2xl sm:text-3xl font-black" style="color: var(--text-primary);">Past Events</h2>
    </div>

    <!-- Timeline layout -->
    <div class="space-y-3">
      {past.map(event => (
        <a
          href={event.pageUrl}
          class="group flex items-center gap-4 sm:gap-6 p-4 sm:p-5 rounded-2xl transition-all duration-300 hover:bg-[var(--bg-card)]"
          style={`border: 1px solid transparent; transition: border-color 0.3s;`}
        >
          <!-- Emoji + dot -->
          <div class="relative flex-shrink-0">
            <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-2xl flex items-center justify-center text-2xl" style="background-color: var(--bg-card);">
              {event.emoji}
            </div>
            <div class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full border-2 flex items-center justify-center" style="background: #1a1a1a; border-color: #374151;">
              <span class="w-2 h-2 rounded-full bg-gray-600"></span>
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <h3 class="font-bold text-sm sm:text-base group-hover:text-yellow-300 transition-colors" style="color: var(--text-primary);">{event.shortName}</h3>
              {event.edition && (
                <span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--bg-hover); color: var(--text-muted);">{event.edition}</span>
              )}
            </div>
            <p class="text-xs sm:text-sm mt-0.5" style="color: var(--text-secondary);">{formatShortDate(event.startDate)} · {event.location}</p>
            {event.winner && (
              <p class="text-xs mt-1 flex items-center gap-1.5" style="color: var(--text-muted);">
                <span>🏆</span>
                <span class="font-medium" style="color: var(--text-secondary);">{event.winner}</span>
              </p>
            )}
          </div>

          <!-- Right side -->
          <div class="flex-shrink-0 flex items-center gap-3">
            {event.pageUrl !== '/events' && (
              <span class="hidden sm:inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold text-white transition-all duration-300 opacity-0 group-hover:opacity-100" style={`background: ${event.color};`}>
                View →
              </span>
            )}
            <span class="text-xs font-bold px-3 py-1 rounded-full" style="background: var(--bg-hover); color: var(--text-muted);">
              {new Date(event.startDate).getFullYear()}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── BOTTOM CTA ─────────────────────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="rounded-2xl p-8 sm:p-12 text-center relative overflow-hidden" style="background-color: var(--bg-card); border: 1px solid var(--border);">
      <div class="absolute inset-0 opacity-30 pointer-events-none" style="background: radial-gradient(ellipse at 20% 50%, rgba(181,12,27,0.3), transparent 60%), radial-gradient(ellipse at 80% 50%, rgba(247,208,0,0.15), transparent 60%);"></div>
      <div class="relative">
        <h3 class="text-2xl sm:text-3xl font-black text-white mb-3">Never Miss an Award Season</h3>
        <p class="text-gray-400 mb-6 max-w-lg mx-auto">Watch all the nominees and winners on TrendiMovies before and after every major ceremony.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/movies" class="px-6 py-3 rounded-xl font-bold transition-all hover:scale-105 hover:shadow-lg" style="background: linear-gradient(135deg, #D4AF37, #B8860B); color: #000;">
            Browse Movies →
          </a>
          <a href="/cannes-2026" class="px-6 py-3 rounded-xl font-bold text-white transition-all hover:scale-105" style="background: linear-gradient(135deg, #B50C1B, #8B0011);">
            🌴 Cannes 2026
          </a>
          <a href="/oscars-2026" class="px-6 py-3 rounded-xl font-bold transition-all hover:scale-105" style="background: rgba(255,255,255,0.07); color: white; border: 1px solid rgba(255,255,255,0.15);">
            🏆 Oscars 2026
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
